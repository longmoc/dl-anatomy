---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Notes on deep learning — theory, intuition, and practice.' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — DL Anatomy</title>
  <meta name="description" content={description} />
  <link rel="stylesheet" href={`${base}katex.min.css`} />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" />
</head>
<body>
  <nav class="site-nav">
    <a href={base} class="nav-brand">DL Anatomy</a>
    <div class="nav-links">
      <a href={`${base}foundations`}>Foundations</a>
      <a href={`${base}optimization`}>Optimization</a>
      <a href={`${base}activations`}>Activations</a>
      <a href={`${base}training`}>Training</a>
      <a href={`${base}architectures`}>Architectures</a>
    </div>
  </nav>

  <main>
    <slot />
  </main>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    gap: 2rem;
    padding: 0 2rem;
    height: 52px;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(8px);
  }
  .nav-brand {
    font-family: var(--mono);
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--accent);
    text-decoration: none;
    letter-spacing: -0.3px;
  }
  .nav-links {
    display: flex;
    gap: 1.5rem;
  }
  .nav-links a {
    font-size: 0.875rem;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .nav-links a:hover { color: var(--text); }
</style>
