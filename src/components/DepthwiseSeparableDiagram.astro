---
interface Props {
  lang?: 'vi' | 'en';
}
const { lang = 'vi' } = Astro.props;

const L = lang === 'en'
  ? {
      standard: 'Standard convolution',
      stdDesc: 'one op mixes space AND channels',
      dwsep: 'Depthwise separable',
      conv: 'conv k×k',
      convSub: 'space + channels',
      depthwise: 'Depthwise',
      dwSub: 'k×k / channel',
      pointwise: 'Pointwise 1×1',
      pwSub: 'mix channels',
      cost: 'cost',
      cap: 'A standard conv filters space and mixes channels in one shot. Depthwise-separable factorizes it: a per-channel spatial filter, then a 1×1 conv that mixes channels — far fewer FLOPs.',
    }
  : {
      standard: 'Convolution chuẩn',
      stdDesc: '  (phép toán trộn cả không gian VÀ kênh)',
      dwsep: 'Depthwise separable',
      conv: 'conv k×k',
      convSub: 'không gian + kênh',
      depthwise: 'Depthwise',
      dwSub: 'k×k / kênh',
      pointwise: 'Pointwise 1×1',
      pwSub: 'trộn kênh',
      cost: 'cost',
      cap: 'Conv chuẩn lọc không gian và trộn kênh cùng lúc. Depthwise-separable tách đôi: lọc không gian theo từng kênh, rồi conv 1×1 trộn kênh — ít FLOPs hơn nhiều.',
    };
---

<figure class="dws" data-lang={lang}>
  <svg viewBox="0 0 560 250" role="img" aria-label="Depthwise separable convolution" class="dws-svg">
    <defs>
      <marker id="dws-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" class="dws-head" />
      </marker>
    </defs>

    <!-- ===== Standard conv (top) ===== -->
    <text x="14" y="24" class="dws-title">{L.standard}</text>
    <text x="14" y="40" class="dws-sub">{L.stdDesc}</text>

    <!-- input channels -->
    <rect x="18" y="74" width="24" height="24" rx="3" class="dws-ch dws-c1" />
    <rect x="26" y="82" width="24" height="24" rx="3" class="dws-ch dws-c2" />
    <rect x="34" y="90" width="24" height="24" rx="3" class="dws-ch dws-c3" />
    <line x1="64" y1="94" x2="96" y2="94" class="dws-line" marker-end="url(#dws-arrow)" />

    <!-- one big kernel that touches all channels -->
    <rect x="100" y="68" width="112" height="52" rx="6" class="dws-box dws-std" />
    <text x="156" y="90" class="dws-boxlbl">{L.conv}</text>
    <text x="156" y="106" class="dws-boxlbl-sm">{L.convSub}</text>
    <line x1="216" y1="94" x2="248" y2="94" class="dws-line" marker-end="url(#dws-arrow)" />

    <!-- output channels -->
    <rect x="252" y="76" width="22" height="22" rx="3" class="dws-ch dws-o1" />
    <rect x="259" y="83" width="22" height="22" rx="3" class="dws-ch dws-o2" />
    <rect x="266" y="90" width="22" height="22" rx="3" class="dws-ch dws-o3" />

    <!-- cost (column-aligned with the bottom row at x=392) -->
    <text x="392" y="88" class="dws-cost">{L.cost}</text>
    <text x="392" y="105" class="dws-costval">k<tspan baseline-shift="super" font-size="8">2</tspan> · C<tspan baseline-shift="sub" font-size="8">in</tspan> · C<tspan baseline-shift="sub" font-size="8">out</tspan></text>

    <!-- divider -->
    <line x1="12" y1="134" x2="548" y2="134" class="dws-divider" />

    <!-- ===== Depthwise separable (bottom) ===== -->
    <text x="14" y="158" class="dws-title">{L.dwsep}</text>

    <!-- input -->
    <rect x="18" y="186" width="22" height="22" rx="3" class="dws-ch dws-c1" />
    <rect x="25" y="193" width="22" height="22" rx="3" class="dws-ch dws-c2" />
    <rect x="32" y="200" width="22" height="22" rx="3" class="dws-ch dws-c3" />
    <line x1="58" y1="206" x2="86" y2="206" class="dws-line" marker-end="url(#dws-arrow)" />

    <!-- depthwise -->
    <rect x="90" y="180" width="78" height="52" rx="6" class="dws-box dws-dw" />
    <text x="129" y="202" class="dws-boxlbl">{L.depthwise}</text>
    <text x="129" y="218" class="dws-boxlbl-sm">{L.dwSub}</text>
    <line x1="170" y1="206" x2="188" y2="206" class="dws-line" marker-end="url(#dws-arrow)" />

    <!-- pointwise 1x1 -->
    <rect x="192" y="180" width="98" height="52" rx="6" class="dws-box dws-pw" />
    <text x="241" y="202" class="dws-boxlbl">{L.pointwise}</text>
    <text x="241" y="218" class="dws-boxlbl-sm">{L.pwSub}</text>
    <line x1="292" y1="206" x2="316" y2="206" class="dws-line" marker-end="url(#dws-arrow)" />

    <!-- output -->
    <rect x="320" y="188" width="20" height="20" rx="3" class="dws-ch dws-o1" />
    <rect x="326" y="194" width="20" height="20" rx="3" class="dws-ch dws-o2" />
    <rect x="332" y="200" width="20" height="20" rx="3" class="dws-ch dws-o3" />

    <!-- cost -->
    <text x="392" y="200" class="dws-cost">{L.cost}</text>
    <text x="392" y="217" class="dws-costval">k<tspan baseline-shift="super" font-size="8">2</tspan> · C<tspan baseline-shift="sub" font-size="8">in</tspan> + C<tspan baseline-shift="sub" font-size="8">in</tspan> · C<tspan baseline-shift="sub" font-size="8">out</tspan></text>
  </svg>
  <figcaption class="dws-cap">{L.cap}</figcaption>
</figure>

<style>
  .dws {
    margin: 1.75rem 0;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--bg2);
    padding: 0.75rem 0 0.2rem;
  }
  .dws-svg { display: block; width: 100%; max-width: 600px; height: auto; margin: 0 auto; }
  .dws-title { fill: var(--text); font-family: var(--mono); font-size: 12.5px; font-weight: 600; }
  .dws-sub { fill: var(--muted); font-family: var(--mono); font-size: 10px; }
  .dws-box { stroke-width: 1.5; fill: var(--bg); }
  .dws-std { stroke: var(--amber); }
  .dws-dw  { stroke: var(--accent); }
  .dws-pw  { stroke: var(--accent2); }
  .dws-boxlbl { fill: var(--text); font-family: var(--mono); font-size: 12.5px; text-anchor: middle; }
  .dws-boxlbl-sm { fill: var(--muted); font-family: var(--mono); font-size: 10.5px; text-anchor: middle; }
  .dws-line { stroke: var(--muted); stroke-width: 1.5; }
  .dws-head { fill: var(--muted); }
  .dws-divider { stroke: var(--border); stroke-width: 1; stroke-dasharray: 4 4; }
  .dws-cost { fill: var(--muted); font-family: var(--mono); font-size: 10px; }
  .dws-costval { fill: var(--accent); font-family: var(--mono); font-size: 11.5px; font-weight: 600; }
  .dws-ch { stroke: var(--bg2); stroke-width: 1; opacity: 0.9; }
  .dws-c1 { fill: var(--accent); }
  .dws-c2 { fill: var(--accent2); }
  .dws-c3 { fill: var(--amber); }
  .dws-o1 { fill: var(--accent); }
  .dws-o2 { fill: var(--accent2); }
  .dws-o3 { fill: var(--amber); }
  .dws-cap {
    font-size: 0.78rem; color: var(--muted); text-align: center;
    padding: 0.5rem 1rem 0.6rem; font-style: italic; line-height: 1.5;
  }
</style>
