---
interface Props {
  lang?: 'vi' | 'en';
}
const { lang = 'vi' } = Astro.props;

const L = lang === 'en'
  ? {
      seq: 'sequence (T tokens)',
      cone: 'same FFN applied to each token (shared weights)',
      op1: 'W₁ , σ  (expand d → 4d)',
      op2: 'W₂  (project 4d → d)',
      din: 'x · d',
      dhid: 'hidden · 4d',
      dout: 'FFN(x) · d',
      cap: 'The FFN is a two-layer MLP applied independently to each token (position-wise, same weights at every position): expand from d to a wider hidden dimension (usually 4d) through W₁ and a nonlinearity σ, then project back to d through W₂. This is where most of a Transformer block’s parameters live.',
    }
  : {
      seq: 'chuỗi (T token)',
      cone: 'cùng một FFN áp cho từng token (chung trọng số)',
      op1: 'W₁ , σ  (mở rộng d → 4d)',
      op2: 'W₂  (chiếu 4d → d)',
      din: 'x · d',
      dhid: 'hidden · 4d',
      dout: 'FFN(x) · d',
      cap: 'FFN là MLP hai lớp áp riêng cho từng token (position-wise, cùng trọng số ở mọi vị trí): mở rộng từ d lên chiều ẩn lớn hơn (thường 4d) qua W₁ và phi tuyến σ, rồi chiếu lại về d qua W₂. Đây là nơi chứa phần lớn tham số của một Transformer block.',
    };

const inX = 150, hidX = 340, outX = 530;
const inY = [130, 170, 210, 250];
const outY = [130, 170, 210, 250];
const hidY = [100, 126, 152, 178, 204, 230, 256, 282];

const seqX = [232, 257, 282, 307, 332, 357]; // sequence squares; index 2 highlighted
---

<figure class="ffn">
  <svg viewBox="0 0 620 322" role="img" aria-label="Transformer feed-forward network" class="ffn-svg">
    <defs>
      <marker id="ffn-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6.5" markerHeight="6.5" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" class="ffn-headm" />
      </marker>
    </defs>

    <!-- sequence strip -->
    <text x="294" y="18" class="ffn-seqlbl">{L.seq}</text>
    {seqX.map((x, i) => (
      <rect x={x} y="28" width="16" height="16" rx="3" class={i === 2 ? 'ffn-tok ffn-tok-hi' : 'ffn-tok'} />
    ))}

    <!-- zoom cone from highlighted token into the MLP -->
    <line x1="282" y1="44" x2="110" y2="104" class="ffn-cone" />
    <line x1="298" y1="44" x2="548" y2="104" class="ffn-cone" />
    <text x="329" y="92" class="ffn-cone-lbl">{L.cone}</text>

    <!-- operation labels -->
    <text x="245" y="106" class="ffn-op">{L.op1}</text>
    <text x="435" y="106" class="ffn-op">{L.op2}</text>

    <!-- edges: input -> hidden -->
    {inY.map(iy => hidY.map(hy => (
      <line x1={inX} y1={iy} x2={hidX} y2={hy} class="ffn-edge" />
    )))}
    <!-- edges: hidden -> output -->
    {hidY.map(hy => outY.map(oy => (
      <line x1={hidX} y1={hy} x2={outX} y2={oy} class="ffn-edge" />
    )))}

    <!-- nodes -->
    {inY.map(y => <circle cx={inX} cy={y} r="9" class="ffn-nin" />)}
    {hidY.map(y => <circle cx={hidX} cy={y} r="9" class="ffn-nhid" />)}
    {outY.map(y => <circle cx={outX} cy={y} r="9" class="ffn-nout" />)}

    <!-- dimension labels -->
    <text x={inX}  y="308" class="ffn-dim">{L.din}</text>
    <text x={hidX} y="308" class="ffn-dim">{L.dhid}</text>
    <text x={outX} y="308" class="ffn-dim">{L.dout}</text>
  </svg>
  <figcaption class="ffn-cap">{L.cap}</figcaption>
</figure>

<style>
  .ffn { margin: 1.75rem 0; border: 1px solid var(--border); border-radius: 10px; background: var(--bg2); padding: 0.8rem 0 0.4rem; }
  .ffn-svg { display: block; width: 100%; max-width: 600px; height: auto; margin: 0 auto; }
  .ffn-seqlbl { fill: var(--muted); font-family: var(--mono); font-size: 10px; text-anchor: middle; }
  .ffn-tok { fill: var(--accent); fill-opacity: 0.45; stroke: var(--accent); stroke-width: 1.2; }
  .ffn-tok-hi { fill-opacity: 0.9; stroke-width: 2; }
  .ffn-cone { stroke: var(--muted); stroke-width: 1; stroke-dasharray: 4 3; opacity: 0.7; }
  .ffn-cone-lbl { fill: var(--muted); font-family: var(--mono); font-size: 10px; text-anchor: middle; font-style: italic; }
  .ffn-op { fill: var(--text); font-family: var(--mono); font-size: 10.5px; text-anchor: middle; }
  .ffn-edge { stroke: var(--muted); stroke-width: 0.7; opacity: 0.28; }
  .ffn-nin { fill: var(--accent); }
  .ffn-nhid { fill: var(--accent2); }
  .ffn-nout { fill: var(--amber); }
  .ffn-dim { fill: var(--text); font-family: var(--mono); font-size: 11px; text-anchor: middle; }
  .ffn-cap { font-size: 0.78rem; color: var(--muted); text-align: center; padding: 0.5rem 1rem 0.6rem; font-style: italic; line-height: 1.5; }
</style>
