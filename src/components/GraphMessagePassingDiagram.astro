---
interface Props {
  lang?: 'vi' | 'en';
}
const { lang = 'vi' } = Astro.props;

const L = lang === 'en'
  ? {
      hL: "v's neighborhood",
      hR: 'update rule',
      oneHop: '1-hop neighbors',
      twoHop: '2-hop',
      self: 'current state',
      aggregate: 'aggregate',
      update: 'update',
      cap: 'A GNN layer: each 1-hop neighbor of v sends a message (hᵤ); the messages are aggregated (sum / mean / attention), then combined with v’s current state hᵥ in the update to give the new state hᵥ′. Stacking another layer lets information from 2-hop nodes (a, b) reach v through its neighbors.',
    }
  : {
      hL: 'lân cận của v',
      hR: 'quy tắc cập nhật',
      oneHop: 'hàng xóm 1-hop',
      twoHop: '2-hop',
      self: 'trạng thái hiện tại',
      aggregate: 'aggregate',
      update: 'update',
      cap: 'Một GNN layer: mỗi hàng xóm 1-hop của v gửi một message (hᵤ); các message được aggregate (sum / mean / attention), rồi kết hợp với trạng thái hiện tại hᵥ ở bước update để ra trạng thái mới hᵥ′. Chồng thêm một layer thì thông tin từ node 2-hop (a, b) lan tới v qua hàng xóm.',
    };
---

<figure class="gmp" data-lang={lang}>
  <svg viewBox="0 0 660 300" role="img" aria-label="Graph neural network message passing" class="gmp-svg">
    <defs>
      <marker id="gmp-msg" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6.5" markerHeight="6.5" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" class="gmp-msg-h" />
      </marker>
      <marker id="gmp-pipe" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6.5" markerHeight="6.5" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" class="gmp-pipe-h" />
      </marker>
      <marker id="gmp-faint" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" class="gmp-faint-h" />
      </marker>
    </defs>

    <text x="170" y="28" class="gmp-h">{L.hL}</text>
    <text x="500" y="28" class="gmp-h">{L.hR}</text>
    <line x1="315" y1="44" x2="315" y2="274" class="gmp-div" />

    <!-- ===== LEFT: neighborhood graph ===== -->
    <!-- 2-hop faint nodes + edges -->
    <g class="gmp-faintg">
      <line x1="44" y1="61" x2="67" y2="72" class="gmp-edge2" marker-end="url(#gmp-faint)" />
      <line x1="47" y1="233" x2="70" y2="236" class="gmp-edge2" marker-end="url(#gmp-faint)" />
      <circle cx="32" cy="56" r="13" class="gmp-node2" /><text x="32" y="60" class="gmp-small">a</text>
      <circle cx="34" cy="232" r="13" class="gmp-node2" /><text x="34" y="236" class="gmp-small">b</text>
    </g>
    <text x="30" y="36" class="gmp-note">{L.twoHop}</text>

    <!-- messages: neighbors -> v -->
    <line x1="100" y1="94" x2="147" y2="137" class="gmp-msg" marker-end="url(#gmp-msg)" />
    <line x1="82" y1="158" x2="140" y2="158" class="gmp-msg" marker-end="url(#gmp-msg)" />
    <line x1="104" y1="222" x2="149" y2="179" class="gmp-msg" marker-end="url(#gmp-msg)" />

    <!-- 1-hop neighbors -->
    <circle cx="85" cy="80" r="20" class="gmp-node" /><text x="85" y="85" class="gmp-label">u₁</text>
    <circle cx="62" cy="158" r="20" class="gmp-node" /><text x="62" y="163" class="gmp-label">u₂</text>
    <circle cx="90" cy="236" r="20" class="gmp-node" /><text x="90" y="241" class="gmp-label">u₃</text>
    <text x="95" y="284" class="gmp-note">{L.oneHop}</text>

    <!-- center v -->
    <circle cx="170" cy="158" r="30" class="gmp-center" />
    <text x="170" y="164" class="gmp-center-text">v</text>

    <!-- ===== RIGHT: update pipeline ===== -->
    <!-- neighbor messages -->
    <rect x="348" y="64" width="56" height="22" rx="6" class="gmp-chip" />
    <text x="376" y="79" class="gmp-chip-t"><tspan>h</tspan><tspan baseline-shift="sub" font-size="8">u₁</tspan></text>
    <rect x="348" y="92" width="56" height="22" rx="6" class="gmp-chip" />
    <text x="376" y="107" class="gmp-chip-t"><tspan>h</tspan><tspan baseline-shift="sub" font-size="8">u₂</tspan></text>
    <rect x="348" y="120" width="56" height="22" rx="6" class="gmp-chip" />
    <text x="376" y="135" class="gmp-chip-t"><tspan>h</tspan><tspan baseline-shift="sub" font-size="8">u₃</tspan></text>

    <line x1="404" y1="75" x2="454" y2="98" class="gmp-pipe" marker-end="url(#gmp-pipe)" />
    <line x1="404" y1="103" x2="454" y2="102" class="gmp-pipe" marker-end="url(#gmp-pipe)" />
    <line x1="404" y1="131" x2="454" y2="106" class="gmp-pipe" marker-end="url(#gmp-pipe)" />

    <!-- aggregate -->
    <rect x="456" y="86" width="96" height="32" rx="7" class="gmp-box" />
    <text x="504" y="106" class="gmp-box-text">{L.aggregate}</text>

    <!-- aggregate -> update -->
    <line x1="504" y1="118" x2="504" y2="160" class="gmp-pipe" marker-end="url(#gmp-pipe)" />

    <!-- self state -> update -->
    <rect x="348" y="168" width="56" height="26" rx="6" class="gmp-chip" />
    <text x="376" y="185" class="gmp-chip-t"><tspan>h</tspan><tspan baseline-shift="sub" font-size="8">v</tspan></text>
    <text x="376" y="210" class="gmp-note">{L.self}</text>
    <line x1="404" y1="181" x2="454" y2="181" class="gmp-pipe" marker-end="url(#gmp-pipe)" />

    <!-- update -->
    <rect x="456" y="165" width="96" height="32" rx="7" class="gmp-box2" />
    <text x="504" y="185" class="gmp-box-text">{L.update}</text>

    <!-- update -> new state -->
    <line x1="504" y1="197" x2="504" y2="234" class="gmp-pipe" marker-end="url(#gmp-pipe)" />
    <rect x="456" y="234" width="96" height="30" rx="7" class="gmp-out" />
    <text x="504" y="253" class="gmp-chip-t"><tspan>h</tspan><tspan baseline-shift="sub" font-size="8">v</tspan><tspan baseline-shift="super" font-size="9">′</tspan></text>
  </svg>
  <figcaption class="gmp-cap">{L.cap}</figcaption>
</figure>

<style>
  .gmp {
    margin: 1.75rem 0;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--bg2);
    padding: 0.75rem 0 0.2rem;
  }
  .gmp-svg { display: block; width: 100%; max-width: 700px; height: auto; margin: 0 auto; }
  .gmp-h { fill: var(--text); font-family: var(--mono); font-size: 13px; font-weight: 600; text-anchor: middle; }
  .gmp-div { stroke: var(--border); stroke-width: 1.2; stroke-dasharray: 4 4; }
  .gmp-node { fill: var(--bg); stroke: var(--accent2); stroke-width: 1.8; }
  .gmp-node2 { fill: var(--bg); stroke: var(--muted); stroke-width: 1.4; }
  .gmp-center { fill: var(--bg); stroke: var(--accent); stroke-width: 2.2; }
  .gmp-edge2 { stroke: var(--muted); stroke-width: 1.2; }
  .gmp-faintg { opacity: 0.5; }
  .gmp-faint-h { fill: var(--muted); }
  .gmp-msg { stroke: var(--accent2); stroke-width: 1.8; }
  .gmp-msg-h { fill: var(--accent2); }
  .gmp-pipe { stroke: var(--text); stroke-width: 1.6; }
  .gmp-pipe-h { fill: var(--text); }
  .gmp-box { fill: var(--bg); stroke: var(--amber); stroke-width: 1.8; }
  .gmp-box2 { fill: var(--bg); stroke: var(--accent); stroke-width: 1.8; }
  .gmp-out { fill: var(--bg); stroke: var(--accent2); stroke-width: 1.8; }
  .gmp-chip { fill: var(--bg); stroke: var(--muted); stroke-width: 1.4; }
  .gmp-label, .gmp-small, .gmp-center-text, .gmp-box-text, .gmp-note, .gmp-chip-t {
    font-family: var(--mono);
    text-anchor: middle;
  }
  .gmp-label { fill: var(--text); font-size: 12px; }
  .gmp-small { fill: var(--muted); font-size: 11px; }
  .gmp-center-text { fill: var(--text); font-size: 16px; font-weight: 700; }
  .gmp-box-text { fill: var(--text); font-size: 12px; font-weight: 600; }
  .gmp-chip-t { fill: var(--text); font-size: 12px; }
  .gmp-note { fill: var(--muted); font-size: 10px; }
  .gmp-cap {
    font-size: 0.78rem;
    color: var(--muted);
    text-align: center;
    padding: 0.5rem 1rem 0.65rem;
    font-style: italic;
    line-height: 1.5;
  }
</style>
