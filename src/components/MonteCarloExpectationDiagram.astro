---
interface Props {
  lang?: 'vi' | 'en';
}
const { lang = 'vi' } = Astro.props;

const mean = (a: number[]) => a.reduce((s, v) => s + v, 0) / a.length;
const baseY = 210, peakY = 95;
const leftCx = 185, rightCx = 530;
const leftS = [160, 188, 206, 224, 258];
const rOff = [-92, -70, -60, -52, -38, -26, -16, -8, 0, 8, 16, 26, 38, 52, 70, 92];
const rightS = rOff.map(o => rightCx + o);
const xbarL = mean(leftS);
const xbarR = mean(rightS);
const curve = (cx: number) =>
  `M${cx - 110},${baseY} C${cx - 45},${baseY} ${cx - 35},${peakY} ${cx},${peakY} C${cx + 35},${peakY} ${cx + 45},${baseY} ${cx + 110},${baseY}`;

const L = lang === 'en'
  ? {
      titleL: `few samples (N=${leftS.length})`,
      titleR: `many samples (N=${rightS.length})`,
      noteL: 'x̄ is off from μ — noisy',
      noteR: 'x̄ ≈ μ — low variance',
      cap: 'A deep-learning loss is an expectation over data, μ = E[X] (dashed line). Monte Carlo estimates it with the sample average x̄ (solid line). With few samples x̄ is off from μ (noisy); with more samples x̄ gets closer and its variance shrinks (≈ σ²/N).',
    }
  : {
      titleL: `ít mẫu (N=${leftS.length})`,
      titleR: `nhiều mẫu (N=${rightS.length})`,
      noteL: 'x̄ lệch khỏi μ — nhiễu',
      noteR: 'x̄ ≈ μ — phương sai thấp',
      cap: 'Loss trong deep learning là một kỳ vọng trên dữ liệu, μ = E[X] (đường gạch). Monte Carlo ước lượng nó bằng trung bình mẫu x̄ (đường liền). Ít mẫu thì x̄ lệch khỏi μ (nhiễu); càng nhiều mẫu x̄ càng sát và phương sai càng nhỏ (≈ σ²/N).',
    };

const panels = [
  { cx: leftCx, xbar: xbarL, samples: leftS, title: L.titleL, note: L.noteL },
  { cx: rightCx, xbar: xbarR, samples: rightS, title: L.titleR, note: L.noteR },
];
---

<figure class="mce" data-lang={lang}>
  <svg viewBox="0 0 720 292" role="img" aria-label="Monte Carlo: sample average estimates the true expectation" class="mce-svg">
    <line x1="360" y1="44" x2="360" y2="266" class="mce-div" />

    {panels.map(p => (
      <g>
        <text x={p.cx} y="28" class="mce-title">{p.title}</text>

        <!-- distribution -->
        <path d={curve(p.cx)} class="mce-curve" fill="none" />
        <line x1={p.cx - 115} y1={baseY} x2={p.cx + 115} y2={baseY} class="mce-axis" />

        <!-- true expectation μ -->
        <line x1={p.cx} y1="80" x2={p.cx} y2="218" class="mce-mu" />
        <text x={p.cx} y="72" class="mce-mu-lbl">μ</text>

        <!-- samples on the axis -->
        {p.samples.map(x => <circle cx={x} cy={baseY} r="3.4" class="mce-dot" />)}

        <!-- sample average x̄ -->
        <line x1={p.xbar} y1="100" x2={p.xbar} y2="228" class="mce-xbar" />
        <text x={p.xbar} y="242" class="mce-xbar-lbl">x̄</text>

        <text x={p.cx} y="262" class="mce-note">{p.note}</text>
      </g>
    ))}
  </svg>
  <figcaption class="mce-cap">{L.cap}</figcaption>
</figure>

<style>
  .mce {
    margin: 1.75rem 0;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--bg2);
    padding: 0.75rem 0 0.2rem;
  }
  .mce-svg { display: block; width: 100%; max-width: 760px; height: auto; margin: 0 auto; }
  .mce-div { stroke: var(--border); stroke-width: 1.2; stroke-dasharray: 4 4; }
  .mce-title { fill: var(--text); font-family: var(--mono); font-size: 12.5px; font-weight: 600; text-anchor: middle; }
  .mce-curve { stroke: var(--accent); stroke-width: 2; }
  .mce-axis { stroke: var(--border); stroke-width: 1.4; }
  .mce-mu { stroke: var(--amber); stroke-width: 1.8; stroke-dasharray: 5 4; }
  .mce-mu-lbl { fill: var(--amber); font-family: var(--mono); font-size: 14px; font-weight: 700; text-anchor: middle; }
  .mce-xbar { stroke: var(--accent2); stroke-width: 2; }
  .mce-xbar-lbl { fill: var(--accent2); font-family: var(--mono); font-size: 14px; font-weight: 700; text-anchor: middle; }
  .mce-dot { fill: var(--accent2); stroke: var(--bg2); stroke-width: 1; }
  .mce-note { fill: var(--muted); font-family: var(--mono); font-size: 11px; text-anchor: middle; }
  .mce-cap {
    font-size: 0.78rem;
    color: var(--muted);
    text-align: center;
    padding: 0.5rem 1rem 0.65rem;
    font-style: italic;
    line-height: 1.5;
  }
</style>
