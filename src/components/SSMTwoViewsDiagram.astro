---
interface Props {
  lang?: 'vi' | 'en';
}
const { lang = 'vi' } = Astro.props;

const L = lang === 'en'
  ? {
      training: 'Training — convolution',
      inference: 'Inference — recurrent',
      scan: 'long convolution / scan',
      parallel: 'whole sequence, in parallel',
      rolling: 'one fixed state, rolled step by step',
      cap: 'The same SSM has two equivalent views: during training it runs as one long convolution over the whole sequence (parallel); at inference it runs as a recurrence, rolling a fixed-size state one token at a time.',
    }
  : {
      training: 'Training — convolution',
      inference: 'Inference — recurrent',
      scan: 'convolution / scan toàn chuỗi',
      parallel: 'cả chuỗi, song song',
      rolling: 'một state cố định, cuộn từng bước',
      cap: 'Cùng một SSM có hai cách nhìn tương đương: khi train nó chạy như một convolution dài trên cả chuỗi (song song); khi infer nó chạy như recurrence, cuộn một state cố định qua từng token.',
    };
---

<figure class="ssv">
  <svg viewBox="0 0 560 250" role="img" aria-label="SSM two views: convolution vs recurrent" class="ssv-svg">
    <defs>
      <marker id="ssv-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" class="ssv-head" />
      </marker>
    </defs>

    <line x1="282" y1="20" x2="282" y2="228" class="ssv-divider" />

    <!-- titles -->
    <text x="141" y="26" class="ssv-title">{L.training}</text>
    <text x="421" y="26" class="ssv-title">{L.inference}</text>

    <g transform="translate(0,16)">
    <!-- ===== Left: convolution ===== -->
    {['1','2','3','4'].map((t,i) => {
      const x = 66 + i*50;
      return (
        <g>
          <circle cx={x} cy="56" r="12" class="ssv-tok" />
          <text x={x} y="60" class="ssv-small">x{t}</text>
          <line x1={x} y1="68" x2={x} y2="88" class="ssv-line" marker-end="url(#ssv-arrow)" />
          <line x1={x} y1="120" x2={x} y2="140" class="ssv-line" marker-end="url(#ssv-arrow)" />
          <circle cx={x} cy="152" r="12" class="ssv-out" />
          <text x={x} y="156" class="ssv-small">y{t}</text>
        </g>
      );
    })}
    <rect x="50" y="90" width="182" height="30" rx="8" class="ssv-bar" />
    <text x="141" y="109" class="ssv-bar-text">{L.scan}</text>
    <text x="141" y="184" class="ssv-note">{L.parallel}</text>

    <!-- ===== Right: recurrent rolling ===== -->
    {['ₜ₋₁','ₜ','ₜ₊₁'].map((t,i) => {
      const x = 345 + i*66;
      return (
        <g>
          <circle cx={x} cy="52" r="11" class="ssv-tok" />
          <text x={x} y="56" class="ssv-small">x{t}</text>
          <line x1={x} y1="63" x2={x} y2="86" class="ssv-line" marker-end="url(#ssv-arrow)" />
          <rect x={x-26} y="88" width="52" height="34" rx="7" class="ssv-state" />
          <text x={x} y="109" class="ssv-state-text">h{t}</text>
          <line x1={x} y1="122" x2={x} y2="142" class="ssv-line" marker-end="url(#ssv-arrow)" />
          <circle cx={x} cy="154" r="11" class="ssv-out" />
          <text x={x} y="158" class="ssv-small">y{t}</text>
        </g>
      );
    })}
    <!-- state rolls forward -->
    <line x1="371" y1="105" x2="397" y2="105" class="ssv-line" marker-end="url(#ssv-arrow)" />
    <line x1="437" y1="105" x2="463" y2="105" class="ssv-line" marker-end="url(#ssv-arrow)" />
    <text x="421" y="184" class="ssv-note">{L.rolling}</text>
    </g>
  </svg>
  <figcaption class="ssv-cap">{L.cap}</figcaption>
</figure>

<style>
  .ssv { margin: 1.75rem 0; border: 1px solid var(--border); border-radius: 10px; background: var(--bg2); padding: 0.8rem 0 0.25rem; }
  .ssv-svg { display: block; width: 100%; max-width: 600px; height: auto; margin: 0 auto; }
  .ssv-title { fill: var(--text); font-family: var(--mono); font-size: 12.5px; font-weight: 600; text-anchor: middle; }
  .ssv-divider { stroke: var(--border); stroke-width: 1; stroke-dasharray: 4 4; }
  .ssv-tok { fill: var(--bg); stroke: var(--amber); stroke-width: 1.6; }
  .ssv-out { fill: var(--bg); stroke: var(--accent2); stroke-width: 1.6; }
  .ssv-state { fill: var(--bg); stroke: var(--accent); stroke-width: 1.7; }
  .ssv-bar { fill: var(--bg3); stroke: var(--accent); stroke-width: 1.5; }
  .ssv-small { fill: var(--text); font-family: var(--mono); font-size: 10px; text-anchor: middle; }
  .ssv-state-text { fill: var(--text); font-family: var(--mono); font-size: 11px; font-weight: 600; text-anchor: middle; }
  .ssv-bar-text { fill: var(--muted); font-family: var(--mono); font-size: 10.5px; text-anchor: middle; }
  .ssv-note { fill: var(--muted); font-family: var(--mono); font-size: 10px; text-anchor: middle; font-style: italic; }
  .ssv-line { stroke: var(--muted); stroke-width: 1.5; }
  .ssv-head { fill: var(--muted); }
  .ssv-cap { font-size: 0.78rem; color: var(--muted); text-align: center; padding: 0.5rem 1rem 0.65rem; font-style: italic; line-height: 1.5; }
</style>
