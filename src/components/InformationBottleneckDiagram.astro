---
interface Props {
  lang?: 'vi' | 'en';
}
const { lang = 'vi' } = Astro.props;

const L = lang === 'en'
  ? {
      title: 'Information view: keep what predicts Y, compress what is irrelevant',
      x: 'input X',
      z: 'representation Z',
      y: 'target Y',
      noise: 'nuisance / noise',
      keep: 'keep useful info',
      drop: 'drop irrelevant detail',
      mi1: 'high I(Z;Y)',
      mi2: 'controlled I(Z;X)',
      cap: 'A representation should preserve information about the target while discarding irrelevant variation. This is the intuition behind compression, bottlenecks, and many self-supervised objectives.',
    }
  : {
      title: 'Góc nhìn thông tin: giữ phần dự đoán Y, nén phần không liên quan',
      x: 'input X',
      z: 'representation Z',
      y: 'target Y',
      noise: 'nhiễu / chi tiết phụ',
      keep: 'giữ thông tin hữu ích',
      drop: 'bỏ chi tiết không cần',
      mi1: 'I(Z;Y) cao',
      mi2: 'I(Z;X) được kiểm soát',
      cap: 'Representation tốt nên giữ thông tin liên quan đến target, đồng thời bỏ bớt biến thiên không cần thiết. Đây là trực giác phía sau compression, bottleneck và nhiều objective self-supervised.',
    };
---

<figure class="ibd" data-lang={lang}>
  <svg viewBox="0 0 720 316" role="img" aria-label="Information bottleneck diagram" class="ibd-svg">
    <defs>
      <marker id="ibd-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" class="ibd-head" />
      </marker>
      <marker id="ibd-arrow2" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" class="ibd-head2" />
      </marker>
    </defs>

    <text x="360" y="26" class="ibd-title">{L.title}</text>

    <!-- main chain: X -> Z -> Y -->
    <rect x="64" y="116" width="118" height="54" rx="10" class="ibd-box" />
    <text x="123" y="148" class="ibd-label">{L.x}</text>

    <line x1="182" y1="143" x2="298" y2="143" class="ibd-line" marker-end="url(#ibd-arrow)" />
    <text x="240" y="127" class="ibd-small">{L.keep}</text>

    <rect x="300" y="108" width="132" height="70" rx="12" class="ibd-z" />
    <text x="366" y="148" class="ibd-label">{L.z}</text>

    <line x1="432" y1="143" x2="554" y2="143" class="ibd-line2" marker-end="url(#ibd-arrow2)" />
    <text x="493" y="127" class="ibd-small">{L.mi1}</text>

    <rect x="556" y="116" width="118" height="54" rx="10" class="ibd-target" />
    <text x="615" y="148" class="ibd-label">{L.y}</text>

    <!-- drop branch under X -->
    <line x1="123" y1="170" x2="123" y2="240" class="ibd-drop-line" marker-end="url(#ibd-arrow)" />
    <text x="134" y="206" class="ibd-small ibd-left">{L.drop}</text>
    <rect x="58" y="244" width="130" height="34" rx="8" class="ibd-noise" />
    <text x="123" y="265" class="ibd-small">{L.noise}</text>

    <!-- bottleneck under Z -->
    <line x1="366" y1="178" x2="366" y2="240" class="ibd-compress" marker-end="url(#ibd-arrow2)" />
    <rect x="310" y="244" width="112" height="34" rx="8" class="ibd-bottle" />
    <text x="366" y="265" class="ibd-bottle-text">bottleneck</text>
    <text x="366" y="296" class="ibd-small">{L.mi2}</text>
  </svg>
  <figcaption class="ibd-cap">{L.cap}</figcaption>
</figure>

<style>
  .ibd {
    margin: 1.75rem 0;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--bg2);
    padding: 0.75rem 0 0.2rem;
  }
  .ibd-svg { display: block; width: 100%; max-width: 780px; height: auto; margin: 0 auto; }
  .ibd-title { fill: var(--text); font-family: var(--mono); font-size: 13px; font-weight: 600; text-anchor: middle; }
  .ibd-box { fill: var(--bg); stroke: var(--accent); stroke-width: 1.8; }
  .ibd-z { fill: var(--bg); stroke: var(--accent2); stroke-width: 2; }
  .ibd-target { fill: var(--bg); stroke: var(--amber); stroke-width: 1.8; }
  .ibd-noise { fill: var(--bg); stroke: var(--border); stroke-width: 1.3; }
  .ibd-bottle { fill: var(--bg); stroke: var(--muted); stroke-width: 1.4; }
  .ibd-line { stroke: var(--accent2); stroke-width: 1.7; }
  .ibd-line2 { stroke: var(--amber); stroke-width: 1.7; }
  .ibd-drop-line { stroke: var(--muted); stroke-width: 1.4; opacity: 0.8; }
  .ibd-compress { stroke: var(--muted); stroke-width: 1.4; stroke-dasharray: 4 4; }
  .ibd-head { fill: var(--muted); }
  .ibd-head2 { fill: var(--amber); }
  .ibd-label, .ibd-small, .ibd-bottle-text {
    font-family: var(--mono);
    text-anchor: middle;
  }
  .ibd-label { fill: var(--text); font-size: 13px; font-weight: 700; }
  .ibd-small { fill: var(--muted); font-size: 10.5px; }
  .ibd-left { text-anchor: start; }
  .ibd-bottle-text { fill: var(--text); font-size: 11px; font-weight: 600; }
  .ibd-cap {
    font-size: 0.78rem;
    color: var(--muted);
    text-align: center;
    padding: 0.5rem 1rem 0.65rem;
    font-style: italic;
    line-height: 1.5;
  }
</style>
