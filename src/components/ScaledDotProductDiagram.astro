---
interface Props {
  lang?: 'vi' | 'en';
}
const { lang = 'vi' } = Astro.props;

const L = lang === 'en'
  ? {
      step: 'scale, softmax',
      cap: 'Scaled dot-product attention in matrix form. Top row (left→right): Q (T×d) times Kᵀ (d×T) gives the score matrix QKᵀ (T×T). Dividing by √dₖ and a row-wise softmax gives the weight matrix A (T×T). Bottom row (right→left): A times V (T×d) gives the output (T×d) — each token becomes a weighted sum of the values.',
    }
  : {
      step: 'chia √dₖ, softmax',
      cap: 'Scaled dot-product attention dạng ma trận. Hàng trên (trái→phải): Q (T×d) nhân Kᵀ (d×T) ra ma trận điểm khớp QKᵀ (T×T). Chia √dₖ và softmax theo hàng được ma trận trọng số A (T×T). Hàng dưới (phải→trái): A nhân V (T×d) ra output (T×d) — mỗi token là tổng có trọng số của các value.',
    };

function grid(x, y, w, h, cols, rows) {
  const vx = Array.from({ length: cols + 1 }, (_, i) => x + (i * w) / cols);
  const hy = Array.from({ length: rows + 1 }, (_, i) => y + (i * h) / rows);
  return { x, y, w, h, vx, hy };
}
// columns aligned: left x≈340, mid x≈439, right x≈561
// top row (L→R):  Q × Kᵀ → QKᵀ
const gQ = grid(318, 67, 45, 90, 5, 10);   // Q   T×d (tall)
const gK = grid(394, 89, 90, 45, 10, 5);   // Kᵀ  d×T (wide)
const gR = grid(516, 67, 90, 90, 10, 10);  // QKᵀ T×T (square)
// bottom row (R→L): A × V → out  (A sits directly under QKᵀ)
const gA = grid(516, 210, 90, 90, 10, 10); // A=softmax T×T (square)
const gV = grid(417, 210, 45, 90, 5, 10);  // V   T×d (tall)
const gO = grid(318, 210, 45, 90, 5, 10);  // out T×d (tall)
---

<figure class="sdp">
  <svg viewBox="0 0 720 330" role="img" aria-label="Scaled dot-product attention" class="sdp-svg">
    <defs>
      <marker id="sdp-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6.5" markerHeight="6.5" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" class="sdp-head" />
      </marker>
    </defs>

    <!-- ============ LEFT: attention pipeline (centered ~x=104) ============ -->
    <line x1="84"  y1="296" x2="84"  y2="262" class="sdp-line" marker-end="url(#sdp-arrow)" />
    <line x1="116" y1="296" x2="116" y2="262" class="sdp-line" marker-end="url(#sdp-arrow)" />
    <line x1="150" y1="296" x2="150" y2="112" class="sdp-line" marker-end="url(#sdp-arrow)" />
    <text x="84"  y="310" class="sdp-io">Q</text>
    <text x="116" y="310" class="sdp-io">K</text>
    <text x="150" y="310" class="sdp-io">V</text>

    <rect x="60" y="234" width="80" height="26" rx="6" class="sdp-box sdp-matmul" />
    <text x="100" y="251" class="sdp-blk">MatMul</text>
    <line x1="100" y1="234" x2="100" y2="210" class="sdp-line" marker-end="url(#sdp-arrow)" />
    <rect x="69" y="184" width="62" height="24" rx="6" class="sdp-box sdp-scale" />
    <text x="100" y="200" class="sdp-blk">Scale</text>
    <line x1="100" y1="184" x2="100" y2="160" class="sdp-line" marker-end="url(#sdp-arrow)" />
    <rect x="61" y="134" width="78" height="26" rx="6" class="sdp-box sdp-softmax" />
    <text x="100" y="151" class="sdp-blk">Softmax</text>
    <line x1="100" y1="134" x2="100" y2="112" class="sdp-line" marker-end="url(#sdp-arrow)" />
    <rect x="60" y="84" width="96" height="26" rx="6" class="sdp-box sdp-matmul" />
    <text x="108" y="101" class="sdp-blk">MatMul</text>
    <line x1="108" y1="84" x2="108" y2="60" class="sdp-line" marker-end="url(#sdp-arrow)" />

    <!-- divider -->
    <line x1="205" y1="50" x2="205" y2="314" class="sdp-divider" />

    <!-- ============ RIGHT top row (L→R): Q × Kᵀ → QKᵀ ============ -->
    <g>
      <rect x={gQ.x} y={gQ.y} width={gQ.w} height={gQ.h} class="sdp-mq" />
      {gQ.vx.map(x => <line x1={x} y1={gQ.y} x2={x} y2={gQ.y + gQ.h} class="sdp-cell" />)}
      {gQ.hy.map(y => <line x1={gQ.x} y1={y} x2={gQ.x + gQ.w} y2={y} class="sdp-cell" />)}
      <text x={gQ.x + gQ.w / 2} y="59" class="sdp-mlbl"><tspan font-style="italic">Q</tspan><tspan baseline-shift="sub" font-size="10">T×d</tspan></text>
    </g>
    <text x="378" y="118" class="sdp-op">×</text>
    <g>
      <rect x={gK.x} y={gK.y} width={gK.w} height={gK.h} class="sdp-mk" />
      {gK.vx.map(x => <line x1={x} y1={gK.y} x2={x} y2={gK.y + gK.h} class="sdp-cell" />)}
      {gK.hy.map(y => <line x1={gK.x} y1={y} x2={gK.x + gK.w} y2={y} class="sdp-cell" />)}
      <text x={gK.x + gK.w / 2} y="81" class="sdp-mlbl"><tspan font-style="italic">K</tspan><tspan baseline-shift="super" font-size="10">⊤</tspan><tspan baseline-shift="sub" font-size="10">d×T</tspan></text>
    </g>
    <line x1="489" y1="112" x2="510" y2="112" class="sdp-line" marker-end="url(#sdp-arrow)" />
    <g>
      <rect x={gR.x} y={gR.y} width={gR.w} height={gR.h} class="sdp-mr" />
      {gR.vx.map(x => <line x1={x} y1={gR.y} x2={x} y2={gR.y + gR.h} class="sdp-cell" />)}
      {gR.hy.map(y => <line x1={gR.x} y1={y} x2={gR.x + gR.w} y2={y} class="sdp-cell" />)}
      <text x={gR.x + gR.w / 2} y="59" class="sdp-mlbl"><tspan>(</tspan><tspan font-style="italic">QK</tspan><tspan baseline-shift="super" font-size="10">⊤</tspan><tspan>)</tspan><tspan baseline-shift="sub" font-size="10">T×T</tspan></text>
    </g>

    <!-- connector straight down: QKᵀ -> (scale, softmax) -> A -->
    <line x1="561" y1="159" x2="561" y2="208" class="sdp-conn" marker-end="url(#sdp-arrow)" />
    <text x="572" y="187" class="sdp-conn-lbl">{L.step}</text>

    <!-- ============ RIGHT bottom row (R→L): A × V → out ============ -->
    <g>
      <rect x={gA.x} y={gA.y} width={gA.w} height={gA.h} class="sdp-mr" />
      {gA.vx.map(x => <line x1={x} y1={gA.y} x2={x} y2={gA.y + gA.h} class="sdp-cell" />)}
      {gA.hy.map(y => <line x1={gA.x} y1={y} x2={gA.x + gA.w} y2={y} class="sdp-cell" />)}
      <text x={gA.x + gA.w / 2} y="314" class="sdp-mlbl"><tspan font-style="italic">A</tspan><tspan baseline-shift="sub" font-size="10">T×T</tspan></text>
    </g>
    <text x="489" y="261" class="sdp-op">×</text>
    <g>
      <rect x={gV.x} y={gV.y} width={gV.w} height={gV.h} class="sdp-mq" />
      {gV.vx.map(x => <line x1={x} y1={gV.y} x2={x} y2={gV.y + gV.h} class="sdp-cell" />)}
      {gV.hy.map(y => <line x1={gV.x} y1={y} x2={gV.x + gV.w} y2={y} class="sdp-cell" />)}
      <text x={gV.x + gV.w / 2} y="314" class="sdp-mlbl"><tspan font-style="italic">V</tspan><tspan baseline-shift="sub" font-size="10">T×d</tspan></text>
    </g>
    <line x1="410" y1="255" x2="389" y2="255" class="sdp-line" marker-end="url(#sdp-arrow)" />
    <g>
      <rect x={gO.x} y={gO.y} width={gO.w} height={gO.h} class="sdp-mk" />
      {gO.vx.map(x => <line x1={x} y1={gO.y} x2={x} y2={gO.y + gO.h} class="sdp-cell" />)}
      {gO.hy.map(y => <line x1={gO.x} y1={y} x2={gO.x + gO.w} y2={y} class="sdp-cell" />)}
      <text x={gO.x + gO.w / 2} y="314" class="sdp-mlbl"><tspan font-style="italic">out</tspan><tspan baseline-shift="sub" font-size="10">T×d</tspan></text>
    </g>
  </svg>
  <figcaption class="sdp-cap">{L.cap}</figcaption>
</figure>

<style>
  .sdp { margin: 1.75rem 0; border: 1px solid var(--border); border-radius: 10px; background: var(--bg2); padding: 0.8rem 0 0.4rem; }
  .sdp-svg { display: block; width: 100%; max-width: 720px; height: auto; margin: 0 auto; }
  .sdp-line { stroke: var(--text); stroke-width: 1.6; fill: none; }
  .sdp-head { fill: var(--text); }
  .sdp-io { fill: var(--text); font-family: var(--mono); font-size: 12px; text-anchor: middle; }
  .sdp-box { fill: var(--bg); stroke-width: 1.8; }
  .sdp-matmul { stroke: var(--accent2); }
  .sdp-scale { stroke: var(--amber); }
  .sdp-softmax { stroke: var(--accent); }
  .sdp-blk { fill: var(--text); font-family: var(--mono); font-size: 11px; text-anchor: middle; }
  .sdp-divider { stroke: var(--muted); stroke-width: 2; opacity: 0.5; }
  .sdp-conn { stroke: var(--muted); stroke-width: 1.4; stroke-dasharray: 5 3; }
  .sdp-conn-lbl { fill: var(--muted); font-family: var(--mono); font-size: 10px; text-anchor: start; font-style: italic; }
  .sdp-mq { fill: var(--amber); fill-opacity: 0.5; stroke: var(--text); stroke-width: 1.4; }
  .sdp-mk { fill: var(--accent); fill-opacity: 0.5; stroke: var(--text); stroke-width: 1.4; }
  .sdp-mr { fill: var(--accent2); fill-opacity: 0.5; stroke: var(--text); stroke-width: 1.4; }
  .sdp-cell { stroke: var(--text); stroke-width: 0.6; opacity: 0.3; }
  .sdp-mlbl { fill: var(--text); font-family: var(--mono); font-size: 15px; text-anchor: middle; }
  .sdp-op { fill: var(--text); font-family: var(--mono); font-size: 20px; text-anchor: middle; }
  .sdp-cap { font-size: 0.78rem; color: var(--muted); text-align: center; padding: 0.5rem 1rem 0.6rem; font-style: italic; line-height: 1.5; }
</style>
