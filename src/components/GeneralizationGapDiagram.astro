---
interface Props {
  lang?: 'vi' | 'en';
}
const { lang = 'vi' } = Astro.props;

const L = lang === 'en'
  ? {
      title: 'Generalization gap: train captures the coarse structure, unseen reveals the detail',
      truef: 'true f',
      train: 'train (seen)',
      unseen: 'unseen',
      fhat: 'learned f̂',
      gap: 'gap',
      cap: 'The true signal has coarse structure plus fine detail. A finite training set (blue) captures only the coarse structure, so the learned f̂ (green) follows the training points and misses the detail. On unseen samples (amber) — exactly the detail the train set lacked — f̂ errs more: the red segments are the generalization gap R(f̂) − R̂(f̂). Low train loss does not guarantee low true risk.',
    }
  : {
      title: 'Generalization gap: train bắt cấu trúc thô, unseen lộ chi tiết',
      truef: 'hàm thật',
      train: 'train (seen)',
      unseen: 'unseen',
      fhat: 'f̂ học được',
      gap: 'gap',
      cap: 'Hàm thật có cả cấu trúc thô lẫn chi tiết nhỏ. Tập train hữu hạn (xanh dương) chỉ bắt được cấu trúc thô, nên f̂ học được (xanh lá) bám theo điểm train và bỏ lỡ chi tiết. Trên sample chưa thấy (amber) — đúng những chi tiết train thiếu — f̂ sai nhiều hơn: các đoạn đỏ là generalization gap R(f̂) − R̂(f̂). Train loss thấp không đảm bảo true risk thấp.',
    };

// ---- true signal: coarse humps + fine bumps ----
const gg = (x: number, mu: number, sig: number) => Math.exp(-0.5 * ((x - mu) / sig) ** 2);
const f = (x: number) => Math.min(1,
  0.12 + 0.50 * gg(x, 0.27, 0.12) + 0.46 * gg(x, 0.72, 0.13)
  + 0.18 * gg(x, 0.45, 0.027) + 0.17 * gg(x, 0.60, 0.024) + 0.16 * gg(x, 0.86, 0.030));

const trainX = [0.06, 0.19, 0.32, 0.53, 0.69, 0.80, 0.93];   // coarse — miss the fine bumps
const unseenX = [0.45, 0.60, 0.86];                          // the fine detail the train set lacked
const tpts = trainX.map(x => ({ x, y: f(x) }));
const bw = 0.12;
const fhat = (x: number) => { let sw = 0, swy = 0; for (const p of tpts) { const u = (x - p.x) / bw; const w = Math.exp(-(u * u)) + 1e-9; sw += w; swy += w * p.y; } return swy / sw; };

// ---- geometry ----
const Wv = 760, PL = 44, PRr = 18, baseY = 250, vTop = 72;
const TX = (x: number) => PL + x * (Wv - PL - PRr);
const TY = (v: number) => baseY - v * (baseY - vTop);
const N = 170;
const grid = Array.from({ length: N }, (_, i) => i / (N - 1));
const truePath = grid.map((x, i) => `${i ? 'L' : 'M'}${TX(x).toFixed(1)},${TY(f(x)).toFixed(1)}`).join(' ');
const trueArea = `M${TX(0).toFixed(1)},${baseY} ` + grid.map(x => `L${TX(x).toFixed(1)},${TY(f(x)).toFixed(1)}`).join(' ') + ` L${TX(1).toFixed(1)},${baseY} Z`;
const fhatPath = grid.map((x, i) => `${i ? 'L' : 'M'}${TX(x).toFixed(1)},${TY(fhat(x)).toFixed(1)}`).join(' ');
const trainCols = trainX.map(x => ({ cx: TX(x), top: TY(f(x)) }));
const unseenCols = unseenX.map(x => ({ cx: TX(x), top: TY(f(x)), fh: TY(fhat(x)) }));
const gapLabel = unseenCols[1]; // middle one for the "gap" label
---

<figure class="ggd" data-lang={lang}>
  <svg viewBox="0 0 760 312" role="img" aria-label="Generalization gap: seen vs unseen samples" class="ggd-svg">
    <text x="380" y="24" class="ggd-title">{L.title}</text>

    <!-- legend -->
    <g transform="translate(44,40)">
      <line x1="0" y1="-3" x2="20" y2="-3" class="ggd-true-line" />
      <text x="26" y="0" class="ggd-leg">{L.truef}</text>
      <rect x="118" y="-9" width="12" height="11" class="ggd-train-sw" />
      <text x="136" y="0" class="ggd-leg">{L.train}</text>
      <rect x="246" y="-9" width="12" height="11" class="ggd-unseen-sw" />
      <text x="264" y="0" class="ggd-leg">{L.unseen}</text>
      <line x1="350" y1="-3" x2="372" y2="-3" class="ggd-fhat" />
      <text x="378" y="0" class="ggd-leg">{L.fhat}</text>
    </g>

    <!-- baseline -->
    <line x1={PL} y1={baseY} x2={Wv - PRr} y2={baseY} class="ggd-axis" />

    <!-- true signal -->
    <path d={trueArea} class="ggd-true-area" />
    <path d={truePath} class="ggd-true-line" fill="none" />

    <!-- train columns (capture coarse structure) -->
    {trainCols.map(c => (
      <g>
        <rect x={c.cx - 5.5} y={c.top} width="11" height={baseY - c.top} class="ggd-train-col" />
        <circle cx={c.cx} cy={c.top} r="2.6" class="ggd-train-dot" />
      </g>
    ))}

    <!-- unseen columns (the missed detail) -->
    {unseenCols.map(c => (
      <g>
        <rect x={c.cx - 5.5} y={c.top} width="11" height={baseY - c.top} class="ggd-unseen-col" />
        <line x1={c.cx} y1={c.fh} x2={c.cx} y2={c.top} class="ggd-gap" />
        <circle cx={c.cx} cy={c.top} r="2.6" class="ggd-unseen-dot" />
      </g>
    ))}

    <!-- learned f̂ (follows train, misses detail) -->
    <path d={fhatPath} class="ggd-fhat" fill="none" />

    <!-- gap label -->
    <text x={gapLabel.cx + 9} y={(gapLabel.top + gapLabel.fh) / 2 + 3} class="ggd-gap-lbl">{L.gap}</text>

    <!-- side annotations -->
    <text x={TX(0.19)} y={baseY + 16} class="ggd-anno ggd-anno-b">R̂ ≈ 0</text>
    <text x={TX(0.60)} y={baseY + 16} class="ggd-anno ggd-anno-a">R &gt; 0</text>
  </svg>
  <figcaption class="ggd-cap">{L.cap}</figcaption>
</figure>

<style>
  .ggd {
    margin: 1.75rem 0;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--bg2);
    padding: 0.75rem 0 0.2rem;
  }
  .ggd-svg { display: block; width: 100%; max-width: 800px; height: auto; margin: 0 auto; }
  .ggd-title { fill: var(--text); font-family: var(--mono); font-size: 12.5px; font-weight: 600; text-anchor: middle; }
  .ggd-leg { fill: var(--muted); font-family: var(--mono); font-size: 10.5px; dominant-baseline: middle; }
  .ggd-axis { stroke: var(--border); stroke-width: 1.2; }
  .ggd-true-area { fill: var(--accent); fill-opacity: 0.08; stroke: none; }
  .ggd-true-line { stroke: var(--accent); stroke-width: 1.6; opacity: 0.55; stroke-dasharray: 5 4; }
  .ggd-train-col { fill: var(--accent); fill-opacity: 0.30; stroke: var(--accent); stroke-width: 1.3; }
  .ggd-train-sw { fill: var(--accent); fill-opacity: 0.30; stroke: var(--accent); stroke-width: 1.3; }
  .ggd-train-dot { fill: var(--accent); }
  .ggd-unseen-col { fill: var(--amber); fill-opacity: 0.22; stroke: var(--amber); stroke-width: 1.3; stroke-dasharray: 3 2; }
  .ggd-unseen-sw { fill: var(--amber); fill-opacity: 0.22; stroke: var(--amber); stroke-width: 1.3; }
  .ggd-unseen-dot { fill: var(--amber); }
  .ggd-fhat { stroke: var(--accent2); stroke-width: 2.6; }
  .ggd-gap { stroke: var(--danger); stroke-width: 2.6; }
  .ggd-gap-lbl { fill: var(--danger); font-family: var(--mono); font-size: 11px; font-weight: 600; }
  .ggd-anno { font-family: var(--mono); font-size: 10px; text-anchor: middle; }
  .ggd-anno-b { fill: var(--accent); }
  .ggd-anno-a { fill: var(--danger); }
  .ggd-cap {
    font-size: 0.78rem;
    color: var(--muted);
    text-align: center;
    padding: 0.5rem 1rem 0.65rem;
    font-style: italic;
    line-height: 1.5;
  }
</style>
