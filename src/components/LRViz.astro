---
interface Props {
  lang?: 'vi' | 'en';
}
const { lang = 'vi' } = Astro.props;

const ui = lang === 'en'
  ? {
      steps: 'Training steps',
      lr: 'η (normalized)',
      replay: '↺ Replay',
      labels: ['Step decay', 'Cosine', 'Cosine + warmup', 'WSD'],
      caption: 'All schedules normalized to η_max = 1. Warmup = 10% of total steps. WSD stable phase = 70%, decay phase = 20%.',
    }
  : {
      steps: 'Bước huấn luyện',
      lr: 'η (chuẩn hoá)',
      replay: '↺ Chạy lại',
      labels: ['Step decay', 'Cosine', 'Cosine + warmup', 'WSD'],
      caption: 'Tất cả schedule chuẩn hoá về η_max = 1. Warmup = 10% tổng số bước. WSD: ổn định 70%, decay 20%.',
    };
---

<div class="lrviz" data-lang={lang}>
  <canvas class="lrviz-canvas"></canvas>
  <div class="lrviz-legend">
    <span class="lrviz-item"><span class="lrviz-dot lrviz-step"></span>{ui.labels[0]}</span>
    <span class="lrviz-item"><span class="lrviz-dot lrviz-cos"></span>{ui.labels[1]}</span>
    <span class="lrviz-item"><span class="lrviz-dot lrviz-cowarm"></span>{ui.labels[2]}</span>
    <span class="lrviz-item"><span class="lrviz-dot lrviz-wsd"></span>{ui.labels[3]}</span>
  </div>
  <div class="lrviz-bottom">
    <p class="lrviz-caption">{ui.caption}</p>
    <button class="lrviz-replay">{ui.replay}</button>
  </div>
</div>

<script>
document.querySelectorAll('.lrviz').forEach(root => {
  const canvas = root.querySelector('.lrviz-canvas') as HTMLCanvasElement;
  const ctx    = canvas.getContext('2d')!;
  const isEn   = root.dataset.lang === 'en';

  const T = 1000;
  const W_STEPS  = 100;  // warmup steps (10%)
  const S_END    = 800;  // stable phase ends (WSD)
  const ETA_MIN  = 0.02;

  // --- Schedule functions (return η in [0,1] for step t ∈ [0,T]) ---
  function stepDecay(t: number): number {
    if (t < 400) return 1.0;
    if (t < 700) return 0.3;
    if (t < 900) return 0.09;
    return 0.027;
  }
  function cosine(t: number): number {
    return ETA_MIN + (1 - ETA_MIN) * 0.5 * (1 + Math.cos(Math.PI * t / T));
  }
  function cosineWarmup(t: number): number {
    if (t < W_STEPS) return (t / W_STEPS);
    const tp = t - W_STEPS, Tp = T - W_STEPS;
    return ETA_MIN + (1 - ETA_MIN) * 0.5 * (1 + Math.cos(Math.PI * tp / Tp));
  }
  function wsd(t: number): number {
    if (t < W_STEPS) return t / W_STEPS;           // warmup
    if (t < S_END)   return 1.0;                   // stable
    const td = t - S_END, Td = T - S_END;           // decay
    return ETA_MIN + (1 - ETA_MIN) * 0.5 * (1 + Math.cos(Math.PI * td / Td));
  }

  type ScheduleDef = { fn: (t: number) => number; colorVar: string; dash: number[] };
  const SCHEDULES: ScheduleDef[] = [
    { fn: stepDecay,    colorVar: '--amber',   dash: [] },
    { fn: cosine,       colorVar: '--muted',   dash: [5, 4] },
    { fn: cosineWarmup, colorVar: '--accent2', dash: [] },
    { fn: wsd,          colorVar: '--accent',  dash: [] },
  ];

  const PL = 42, PR = 16, PT = 14, PB = 36;
  let W = 0, H = 0;
  const tx = (t: number) => PL + (t / T) * (W - PL - PR);
  const ty = (v: number) => (H - PB) - v * (H - PT - PB);
  const cv = (n: string) => getComputedStyle(document.documentElement).getPropertyValue(n).trim();

  // Animation: draw cursor moving across chart
  const CYCLE = 4000;
  const TICK  = 40;
  let progress = 1.0; // 0→1, fully drawn on load
  let elapsed  = 0;
  let animating = false;

  function draw(pct: number) {
    const rect = canvas.getBoundingClientRect();
    W = rect.width; H = rect.height;
    if (!W || !H) return;
    const dpr = window.devicePixelRatio || 1;
    if (canvas.width !== W * dpr) { canvas.width = W * dpr; canvas.height = H * dpr; }
    ctx.save();
    ctx.scale(dpr, dpr);

    const bg     = cv('--bg');
    const border = cv('--border');
    const muted  = cv('--muted');

    ctx.fillStyle = bg;
    ctx.fillRect(0, 0, W, H);

    // Grid lines + y-axis ticks
    ctx.strokeStyle = border;
    ctx.lineWidth = 1;
    ctx.setLineDash([3, 5]);
    ctx.globalAlpha = 0.5;
    [0.25, 0.5, 0.75, 1.0].forEach(v => {
      ctx.beginPath();
      ctx.moveTo(PL, ty(v));
      ctx.lineTo(W - PR, ty(v));
      ctx.stroke();
    });
    ctx.setLineDash([]);
    ctx.globalAlpha = 1;

    // Axis tick labels
    ctx.fillStyle = muted;
    ctx.font = `10px var(--mono, monospace)`;
    ctx.textAlign = 'right';
    [0, 0.25, 0.5, 0.75, 1.0].forEach(v => {
      ctx.fillText(v.toFixed(v === 0 ? 0 : 2), PL - 5, ty(v) + 3.5);
    });

    // Warmup marker
    ctx.strokeStyle = muted;
    ctx.lineWidth = 1;
    ctx.setLineDash([2, 5]);
    ctx.globalAlpha = 0.35;
    ctx.beginPath();
    ctx.moveTo(tx(W_STEPS), PT);
    ctx.lineTo(tx(W_STEPS), H - PB);
    ctx.stroke();
    ctx.setLineDash([]);
    ctx.globalAlpha = 1;

    // WSD phase markers
    ctx.setLineDash([2, 5]);
    ctx.globalAlpha = 0.2;
    [S_END].forEach(step => {
      ctx.beginPath();
      ctx.moveTo(tx(step), PT);
      ctx.lineTo(tx(step), H - PB);
      ctx.stroke();
    });
    ctx.setLineDash([]);
    ctx.globalAlpha = 1;

    // X-axis
    ctx.strokeStyle = border;
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(PL, H - PB);
    ctx.lineTo(W - PR, H - PB);
    ctx.stroke();

    // X tick labels
    ctx.fillStyle = muted;
    ctx.textAlign = 'center';
    [0, 0.25, 0.5, 0.75, 1.0].forEach(f => {
      const t = Math.round(f * T);
      ctx.fillText(t === 0 ? '0' : `${t}`, tx(t), H - PB + 14);
    });

    // Axis labels
    ctx.fillStyle = muted;
    ctx.font = `10px var(--mono, monospace)`;
    ctx.textAlign = 'center';
    const stepLabel = isEn ? 'step' : 'bước';
    ctx.fillText(stepLabel, PL + (W - PL - PR) / 2, H - 2);
    // y label rotated
    ctx.save();
    ctx.translate(10, PT + (H - PT - PB) / 2);
    ctx.rotate(-Math.PI / 2);
    ctx.fillText('η', 0, 0);
    ctx.restore();

    // Draw schedule curves up to pct
    const tMax = pct * T;
    SCHEDULES.forEach(s => {
      const color = cv(s.colorVar);
      ctx.beginPath();
      ctx.strokeStyle = color;
      ctx.lineWidth = 2;
      ctx.setLineDash(s.dash);
      let started = false;
      for (let t = 0; t <= Math.min(tMax, T); t += 2) {
        const x = tx(t), y = ty(s.fn(t));
        if (!started) { ctx.moveTo(x, y); started = true; }
        else ctx.lineTo(x, y);
      }
      ctx.stroke();
      ctx.setLineDash([]);
    });

    // Cursor line
    if (pct < 1) {
      ctx.strokeStyle = muted;
      ctx.lineWidth = 1;
      ctx.globalAlpha = 0.4;
      ctx.beginPath();
      ctx.moveTo(tx(tMax), PT);
      ctx.lineTo(tx(tMax), H - PB);
      ctx.stroke();
      ctx.globalAlpha = 1;
    }

    ctx.restore();
  }

  // Start with full draw, replay animates from start
  draw(1.0);

  let lastTick = 0;
  function loop(ts: number) {
    if (!animating) return;
    if (ts - lastTick >= TICK) {
      elapsed += ts - lastTick;
      lastTick = ts;
      progress = Math.min(elapsed / CYCLE, 1.0);
      draw(progress);
      if (progress >= 1.0) { animating = false; }
    }
    requestAnimationFrame(loop);
  }

  root.querySelector('.lrviz-replay')?.addEventListener('click', () => {
    progress = 0; elapsed = 0; animating = true;
    lastTick = 0;
    requestAnimationFrame(loop);
  });

  const ro = new ResizeObserver(() => draw(progress));
  ro.observe(canvas);
});
</script>

<style>
  .lrviz {
    margin: 1.75rem 0;
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    background: var(--bg2);
    padding-bottom: 0.25rem;
  }
  .lrviz-canvas {
    width: 100%;
    height: 210px;
    display: block;
    background: var(--bg);
  }
  .lrviz-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.1rem;
    padding: 0.55rem 0.9rem 0.35rem;
    border-top: 1px solid var(--border);
  }
  .lrviz-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--muted);
  }
  .lrviz-dot {
    width: 22px; height: 3px;
    border-radius: 2px;
    flex-shrink: 0;
  }
  .lrviz-step   { background: var(--amber); }
  .lrviz-cos    { background: var(--muted); }
  .lrviz-cowarm { background: var(--accent2); }
  .lrviz-wsd    { background: var(--accent); }
  .lrviz-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.35rem 0.9rem 0.6rem;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .lrviz-caption {
    font-size: 0.78rem;
    color: var(--muted);
    font-style: italic;
    line-height: 1.5;
    flex: 1;
  }
  .lrviz-replay {
    font-family: var(--mono);
    font-size: 0.75rem;
    padding: 0.22em 0.75em;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--bg);
    color: var(--muted);
    cursor: pointer;
    white-space: nowrap;
    transition: color 0.12s, border-color 0.12s;
    flex-shrink: 0;
  }
  .lrviz-replay:hover { color: var(--text); border-color: var(--text); }
</style>
