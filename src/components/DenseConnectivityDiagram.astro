---
interface Props {
  lang?: 'vi' | 'en';
}
const { lang = 'vi' } = Astro.props;

const L = lang === 'en'
  ? {
      resnet: 'ResNet — add',
      dense: 'DenseNet — concatenate',
      cap: 'ResNet adds the input to each block (one skip). DenseNet feeds every layer to all later layers (concatenation) — maximal feature reuse and many short gradient paths back to the start.',
    }
  : {
      resnet: 'ResNet — cộng',
      dense: 'DenseNet — concatenate',
      cap: 'ResNet cộng input vào mỗi block (một skip). DenseNet đưa mỗi layer tới mọi layer sau (concatenate) — tái dùng feature tối đa và nhiều đường gradient ngắn về layer đầu.',
    };
---

<figure class="dcd" data-lang={lang}>
  <svg viewBox="0 0 460 200" role="img" aria-label="Dense connectivity vs residual" class="dcd-svg">
    <defs>
      <marker id="dcd-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" class="dcd-head" />
      </marker>
      <marker id="dcd-arrow2" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" class="dcd-head2" />
      </marker>
    </defs>

    <!-- ===== ResNet (left) ===== -->
    <text x="20" y="20" class="dcd-title">{L.resnet}</text>
    <!-- 4 nodes in a row -->
    <g class="dcd-resnet">
      <circle cx="40" cy="110" r="13" class="dcd-node" /><text x="40" y="114" class="dcd-nlbl">x₀</text>
      <circle cx="110" cy="110" r="13" class="dcd-node" /><text x="110" y="114" class="dcd-nlbl">x₁</text>
      <circle cx="180" cy="110" r="13" class="dcd-node" /><text x="180" y="114" class="dcd-nlbl">x₂</text>
      <!-- sequential -->
      <line x1="53" y1="110" x2="95" y2="110" class="dcd-line" marker-end="url(#dcd-arrow)" />
      <line x1="123" y1="110" x2="165" y2="110" class="dcd-line" marker-end="url(#dcd-arrow)" />
      <!-- skip (add) arcs, one step -->
      <path d="M40,97 Q75,60 110,97" class="dcd-skip" fill="none" marker-end="url(#dcd-arrow)" />
      <path d="M110,97 Q145,60 180,97" class="dcd-skip" fill="none" marker-end="url(#dcd-arrow)" />
      <text x="145" y="150" class="dcd-note">{lang === 'en' ? '+ : one skip per block' : '+ : một skip / block'}</text>
    </g>

    <!-- divider -->
    <line x1="232" y1="14" x2="232" y2="186" class="dcd-divider" />

    <!-- ===== DenseNet (right) ===== -->
    <text x="250" y="20" class="dcd-title">{L.dense}</text>
    <g class="dcd-dense" transform="translate(238,0)">
      <circle cx="30" cy="110" r="13" class="dcd-node2" /><text x="30" y="114" class="dcd-nlbl">x₀</text>
      <circle cx="100" cy="110" r="13" class="dcd-node2" /><text x="100" y="114" class="dcd-nlbl">x₁</text>
      <circle cx="170" cy="110" r="13" class="dcd-node2" /><text x="170" y="114" class="dcd-nlbl">x₂</text>
      <circle cx="210" cy="110" r="13" class="dcd-node2" /><text x="210" y="114" class="dcd-nlbl">x₃</text>
      <!-- every layer to all later layers -->
      <line x1="43" y1="110" x2="87" y2="110" class="dcd-line2" marker-end="url(#dcd-arrow2)" />
      <line x1="113" y1="110" x2="157" y2="110" class="dcd-line2" marker-end="url(#dcd-arrow2)" />
      <line x1="183" y1="110" x2="197" y2="110" class="dcd-line2" marker-end="url(#dcd-arrow2)" />
      <!-- dense skips above -->
      <path d="M30,97 Q65,62 100,97" class="dcd-skip2" fill="none" marker-end="url(#dcd-arrow2)" />
      <path d="M30,97 Q100,40 170,97" class="dcd-skip2" fill="none" marker-end="url(#dcd-arrow2)" />
      <path d="M30,97 Q120,24 210,97" class="dcd-skip2" fill="none" marker-end="url(#dcd-arrow2)" />
      <path d="M100,97 Q135,62 170,97" class="dcd-skip2" fill="none" marker-end="url(#dcd-arrow2)" />
      <path d="M100,123 Q155,170 210,123" class="dcd-skip2" fill="none" marker-end="url(#dcd-arrow2)" />
      <path d="M170,97 Q190,80 210,97" class="dcd-skip2" fill="none" marker-end="url(#dcd-arrow2)" />
      <text x="120" y="186" class="dcd-note">{lang === 'en' ? 'concat : to all later layers' : 'concat : nối tới mọi layer sau'}</text>
    </g>
  </svg>
  <figcaption class="dcd-cap">{L.cap}</figcaption>
</figure>

<style>
  .dcd {
    margin: 1.75rem 0;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--bg2);
    padding: 0.75rem 0 0.2rem;
  }
  .dcd-svg { display: block; width: 100%; max-width: 470px; height: auto; margin: 0 auto; }
  .dcd-title { fill: var(--text); font-family: var(--mono); font-size: 12px; font-weight: 600; }
  .dcd-node { fill: var(--bg); stroke: var(--amber); stroke-width: 1.8; }
  .dcd-node2 { fill: var(--bg); stroke: var(--accent2); stroke-width: 1.8; }
  .dcd-nlbl { fill: var(--text); font-family: var(--mono); font-size: 10px; text-anchor: middle; }
  .dcd-line { stroke: var(--muted); stroke-width: 1.5; }
  .dcd-line2 { stroke: var(--muted); stroke-width: 1.5; }
  .dcd-head { fill: var(--muted); }
  .dcd-head2 { fill: var(--accent2); }
  .dcd-skip { stroke: var(--amber); stroke-width: 1.5; }
  .dcd-skip2 { stroke: var(--accent2); stroke-width: 1.3; opacity: 0.75; }
  .dcd-divider { stroke: var(--border); stroke-width: 1; stroke-dasharray: 4 4; }
  .dcd-note { fill: var(--muted); font-family: var(--mono); font-size: 9px; text-anchor: middle; }
  .dcd-cap {
    font-size: 0.78rem; color: var(--muted); text-align: center;
    padding: 0.5rem 1rem 0.6rem; font-style: italic; line-height: 1.5;
  }
</style>
