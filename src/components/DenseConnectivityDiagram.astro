---
interface Props {
  lang?: 'vi' | 'en';
}
const { lang = 'vi' } = Astro.props;

const L = lang === 'en'
  ? {
      resnet: 'ResNet — add',
      dense: 'DenseNet — concatenate',
      resnetNote: '+ : one skip per block',
      denseNote: 'concat : to all later layers',
      cap: 'ResNet adds the input to each block (one skip). DenseNet feeds every layer to all later layers (concatenation) — maximal feature reuse and many short gradient paths back to the start.',
    }
  : {
      resnet: 'ResNet — cộng',
      dense: 'DenseNet — concatenate',
      resnetNote: '+ : một skip / block',
      denseNote: 'concat : nối tới mọi layer sau',
      cap: 'ResNet cộng input vào mỗi block (một skip). DenseNet đưa mỗi layer tới mọi layer sau (concatenate) — tái dùng feature tối đa và nhiều đường gradient ngắn về layer đầu.',
    };
---

<figure class="dcd" data-lang={lang}>
  <svg viewBox="0 0 480 210" role="img" aria-label="Dense connectivity vs residual" class="dcd-svg">
    <defs>
      <marker id="dcd-a1" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" class="dcd-head" />
      </marker>
      <marker id="dcd-a2" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" class="dcd-head2" />
      </marker>
    </defs>

    <!-- divider -->
    <line x1="240" y1="14" x2="240" y2="198" class="dcd-divider" />

    <!-- ===== ResNet panel (left, centered around x=120) ===== -->
    <text x="120" y="24" class="dcd-title">{L.resnet}</text>
    <!-- nodes at 50, 120, 190 -->
    <circle cx="50" cy="108" r="14" class="dcd-node" /><text x="50" y="112" class="dcd-nlbl">x₀</text>
    <circle cx="120" cy="108" r="14" class="dcd-node" /><text x="120" y="112" class="dcd-nlbl">x₁</text>
    <circle cx="190" cy="108" r="14" class="dcd-node" /><text x="190" y="112" class="dcd-nlbl">x₂</text>
    <!-- sequential -->
    <line x1="64" y1="108" x2="106" y2="108" class="dcd-line" marker-end="url(#dcd-a1)" />
    <line x1="134" y1="108" x2="176" y2="108" class="dcd-line" marker-end="url(#dcd-a1)" />
    <!-- skip (add) arcs, one step -->
    <path d="M50,94 Q85,56 120,94" class="dcd-skip" fill="none" marker-end="url(#dcd-a1)" />
    <path d="M120,94 Q155,56 190,94" class="dcd-skip" fill="none" marker-end="url(#dcd-a1)" />
    <text x="120" y="190" class="dcd-note">{L.resnetNote}</text>

    <!-- ===== DenseNet panel (right, centered around x=360) ===== -->
    <text x="360" y="24" class="dcd-title">{L.dense}</text>
    <!-- nodes at 270, 330, 390, 450 -->
    <circle cx="270" cy="108" r="14" class="dcd-node2" /><text x="270" y="112" class="dcd-nlbl">x₀</text>
    <circle cx="330" cy="108" r="14" class="dcd-node2" /><text x="330" y="112" class="dcd-nlbl">x₁</text>
    <circle cx="390" cy="108" r="14" class="dcd-node2" /><text x="390" y="112" class="dcd-nlbl">x₂</text>
    <circle cx="450" cy="108" r="14" class="dcd-node2" /><text x="450" y="112" class="dcd-nlbl">x₃</text>
    <!-- adjacent sequential -->
    <line x1="284" y1="108" x2="316" y2="108" class="dcd-line2" marker-end="url(#dcd-a2)" />
    <line x1="344" y1="108" x2="376" y2="108" class="dcd-line2" marker-end="url(#dcd-a2)" />
    <line x1="404" y1="108" x2="436" y2="108" class="dcd-line2" marker-end="url(#dcd-a2)" />
    <!-- dense skips above (non-adjacent pairs) -->
    <path d="M270,94 Q330,56 390,94" class="dcd-skip2" fill="none" marker-end="url(#dcd-a2)" />
    <path d="M330,94 Q390,56 450,94" class="dcd-skip2" fill="none" marker-end="url(#dcd-a2)" />
    <path d="M270,94 Q360,34 450,94" class="dcd-skip2" fill="none" marker-end="url(#dcd-a2)" />
    <text x="360" y="190" class="dcd-note">{L.denseNote}</text>
  </svg>
  <figcaption class="dcd-cap">{L.cap}</figcaption>
</figure>

<style>
  .dcd {
    margin: 1.75rem 0;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--bg2);
    padding: 0.75rem 0 0.2rem;
  }
  .dcd-svg { display: block; width: 100%; max-width: 560px; height: auto; margin: 0 auto; }
  .dcd-title { fill: var(--text); font-family: var(--mono); font-size: 12.5px; font-weight: 600; text-anchor: middle; }
  .dcd-node { fill: var(--bg); stroke: var(--amber); stroke-width: 1.8; }
  .dcd-node2 { fill: var(--bg); stroke: var(--accent2); stroke-width: 1.8; }
  .dcd-nlbl { fill: var(--text); font-family: var(--mono); font-size: 11px; text-anchor: middle; }
  .dcd-line { stroke: var(--muted); stroke-width: 1.5; }
  .dcd-line2 { stroke: var(--muted); stroke-width: 1.5; }
  .dcd-head { fill: var(--muted); }
  .dcd-head2 { fill: var(--accent2); }
  .dcd-skip { stroke: var(--amber); stroke-width: 1.5; }
  .dcd-skip2 { stroke: var(--accent2); stroke-width: 1.3; opacity: 0.75; }
  .dcd-divider { stroke: var(--border); stroke-width: 1; stroke-dasharray: 4 4; }
  .dcd-note { fill: var(--muted); font-family: var(--mono); font-size: 9.5px; text-anchor: middle; }
  .dcd-cap {
    font-size: 0.78rem; color: var(--muted); text-align: center;
    padding: 0.5rem 1rem 0.6rem; font-style: italic; line-height: 1.5;
  }
</style>
