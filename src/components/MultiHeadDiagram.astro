---
interface Props {
  lang?: 'vi' | 'en';
}
const { lang = 'vi' } = Astro.props;

const L = lang === 'en'
  ? {
      embed: 'shared token embeddings',
      head1: 'Head 1 — one relation',
      head2: 'Head 2 — a different relation',
      concat: 'concat → Wᴼ',
      output: 'output',
      cap: 'Each head applies its own learned projections Wᵢ^Q, Wᵢ^K, Wᵢ^V to the shared embeddings, placing the same tokens in a different subspace — so each head can attend along a different relation. The head outputs are concatenated and mixed by Wᴼ.',
    }
  : {
      embed: 'embedding token (dùng chung)',
      head1: 'Head 1 — một quan hệ',
      head2: 'Head 2 — quan hệ khác',
      concat: 'concat → Wᴼ',
      output: 'output',
      cap: 'Mỗi head áp các projection học được Wᵢ^Q, Wᵢ^K, Wᵢ^V lên cùng bộ embedding, đặt các token vào một subspace khác nhau — nên mỗi head có thể attention theo một quan hệ khác. Output các head được nối lại và trộn bởi Wᴼ.',
    };

const tokens = ['the', 'cat', 'sat', 'mat'];
// dot positions per head (absolute SVG coords) — same tokens, different arrangement
const head1 = [
  { t: 'the', x: 95,  y: 232 },
  { t: 'cat', x: 150, y: 192 },
  { t: 'sat', x: 120, y: 244 },
  { t: 'mat', x: 188, y: 206 },
];
const head2 = [
  { t: 'the', x: 360, y: 202 },
  { t: 'cat', x: 472, y: 236 },
  { t: 'sat', x: 402, y: 182 },
  { t: 'mat', x: 448, y: 214 },
];
---

<figure class="mha">
  <svg viewBox="0 0 560 336" role="img" aria-label="Multi-head attention overview" class="mha-svg">
    <defs>
      <marker id="mha-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" class="mha-head" />
      </marker>
    </defs>

    <!-- shared embeddings -->
    <rect x="166" y="18" width="228" height="40" rx="9" class="mha-embed-box" />
    {tokens.map((t,i) => (
      <g>
        <circle cx={196 + i*50} cy="38" r="5" class="mha-edot" />
        <text x={196 + i*50} y="42" class="mha-chip">{t}</text>
      </g>
    ))}
    <text x="280" y="12" class="mha-lbl">{L.embed}</text>

    <!-- projection arrows to heads -->
    <line x1="240" y1="58" x2="150" y2="146" class="mha-line" marker-end="url(#mha-arrow)" />
    <line x1="320" y1="58" x2="410" y2="146" class="mha-line" marker-end="url(#mha-arrow)" />
    <text x="178" y="104" class="mha-proj">
      <tspan>W</tspan><tspan baseline-shift="sub" font-size="8">1</tspan><tspan baseline-shift="super" font-size="8">Q</tspan>
      <tspan dx="3">W</tspan><tspan baseline-shift="sub" font-size="8">1</tspan><tspan baseline-shift="super" font-size="8">K</tspan>
      <tspan dx="3">W</tspan><tspan baseline-shift="sub" font-size="8">1</tspan><tspan baseline-shift="super" font-size="8">V</tspan>
    </text>
    <text x="382" y="104" class="mha-proj">
      <tspan>W</tspan><tspan baseline-shift="sub" font-size="8">2</tspan><tspan baseline-shift="super" font-size="8">Q</tspan>
      <tspan dx="3">W</tspan><tspan baseline-shift="sub" font-size="8">2</tspan><tspan baseline-shift="super" font-size="8">K</tspan>
      <tspan dx="3">W</tspan><tspan baseline-shift="sub" font-size="8">2</tspan><tspan baseline-shift="super" font-size="8">V</tspan>
    </text>

    <!-- Head 1 -->
    <text x="150" y="142" class="mha-htitle">{L.head1}</text>
    <rect x="30" y="148" width="240" height="120" rx="9" class="mha-headbox" />
    <line x1="60" y1="166" x2="60" y2="256" class="mha-axis" />
    <line x1="60" y1="256" x2="252" y2="256" class="mha-axis" />
    {head1.map(d => (
      <g>
        <circle cx={d.x} cy={d.y} r="5" class="mha-dot1" />
        <text x={d.x + 9} y={d.y + 4} class="mha-dlbl">{d.t}</text>
      </g>
    ))}

    <!-- Head 2 -->
    <text x="410" y="142" class="mha-htitle">{L.head2}</text>
    <rect x="290" y="148" width="240" height="120" rx="9" class="mha-headbox" />
    <line x1="320" y1="166" x2="320" y2="256" class="mha-axis" />
    <line x1="320" y1="256" x2="512" y2="256" class="mha-axis" />
    {head2.map(d => (
      <g>
        <circle cx={d.x} cy={d.y} r="5" class="mha-dot2" />
        <text x={d.x + 9} y={d.y + 4} class="mha-dlbl">{d.t}</text>
      </g>
    ))}

    <!-- concat + output -->
    <line x1="150" y1="268" x2="252" y2="290" class="mha-line" marker-end="url(#mha-arrow)" />
    <line x1="410" y1="268" x2="308" y2="290" class="mha-line" marker-end="url(#mha-arrow)" />
    <rect x="208" y="292" width="144" height="28" rx="8" class="mha-concat" />
    <text x="280" y="310" class="mha-concat-text">{L.concat}</text>
  </svg>
  <figcaption class="mha-cap">{L.cap}</figcaption>
</figure>

<style>
  .mha { margin: 1.75rem 0; border: 1px solid var(--border); border-radius: 10px; background: var(--bg2); padding: 0.8rem 0 0.25rem; }
  .mha-svg { display: block; width: 100%; max-width: 600px; height: auto; margin: 0 auto; }
  .mha-embed-box { fill: var(--bg); stroke: var(--accent); stroke-width: 1.6; }
  .mha-edot { fill: var(--accent); }
  .mha-chip { fill: var(--text); font-family: var(--mono); font-size: 9.5px; text-anchor: middle; dominant-baseline: hanging; }
  .mha-lbl { fill: var(--muted); font-family: var(--mono); font-size: 10px; text-anchor: middle; }
  .mha-line { stroke: var(--muted); stroke-width: 1.5; }
  .mha-head { fill: var(--muted); }
  .mha-proj { fill: var(--text); font-family: var(--mono); font-size: 11px; text-anchor: middle; }
  .mha-htitle { fill: var(--text); font-family: var(--mono); font-size: 11.5px; font-weight: 600; text-anchor: middle; }
  .mha-headbox { fill: var(--bg); stroke: var(--border); stroke-width: 1.2; }
  .mha-axis { stroke: var(--muted); stroke-width: 1.2; opacity: 0.6; }
  .mha-dot1 { fill: var(--accent); }
  .mha-dot2 { fill: var(--accent2); }
  .mha-dlbl { fill: var(--muted); font-family: var(--mono); font-size: 9px; text-anchor: start; }
  .mha-concat { fill: var(--bg); stroke: var(--amber); stroke-width: 1.6; }
  .mha-concat-text { fill: var(--text); font-family: var(--mono); font-size: 11px; text-anchor: middle; }
  .mha-cap { font-size: 0.78rem; color: var(--muted); text-align: center; padding: 0.5rem 1rem 0.6rem; font-style: italic; line-height: 1.5; }
</style>
