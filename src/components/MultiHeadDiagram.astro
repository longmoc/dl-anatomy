---
interface Props {
  lang?: 'vi' | 'en';
}
const { lang = 'vi' } = Astro.props;

const L = lang === 'en'
  ? {
      orig: 'Original embeddings (shared)',
      head1: 'Head 1',
      head2: 'Head 2',
      concat: 'concat',
      output: 'output',
      cap: 'Each head has its own projections Wᵢ^Q, Wᵢ^K, Wᵢ^V, turning the shared embeddings into its own Q/K/V spaces — and because the projections differ, each head arranges the same tokens differently and captures a different relation. The head outputs are concatenated and mixed by Wᴼ.',
    }
  : {
      orig: 'Embedding gốc (dùng chung)',
      head1: 'Head 1',
      head2: 'Head 2',
      concat: 'concat',
      output: 'output',
      cap: 'Mỗi head có bộ projection riêng Wᵢ^Q, Wᵢ^K, Wᵢ^V, biến cùng một bộ embedding thành các không gian Q/K/V riêng — vì projection khác nhau nên mỗi head sắp xếp cùng các token một kiểu khác, bắt một quan hệ khác. Output các head được concat rồi trộn bởi Wᴼ.',
    };

// layouts: same 4 tokens placed differently (fractions of plot area)
const layA = [['the',.22,.32],['cat',.55,.70],['sat',.42,.18],['mat',.78,.52]];
const layB = [['the',.28,.62],['cat',.62,.42],['sat',.46,.84],['mat',.72,.24]];
const layC = [['the',.32,.24],['cat',.50,.72],['sat',.74,.54],['mat',.20,.48]];
const layD = [['the',.60,.30],['cat',.28,.60],['sat',.76,.72],['mat',.46,.38]];
const layE = [['the',.50,.78],['cat',.70,.48],['sat',.24,.40],['mat',.56,.20]];
const layF = [['the',.40,.50],['cat',.68,.72],['sat',.30,.26],['mat',.74,.36]];

const accent = 'var(--accent)';
const accent2 = 'var(--accent2)';
const amber = 'var(--amber)';

function mk(ax, ay, w, h, lay, color) {
  return lay.map(([t, fx, fy]) => {
    const x = ax + fx * w;
    const y = ay - fy * h;
    const left = fx > 0.62;
    return { t, x, y, color, lx: left ? x - 6 : x + 6, anchor: left ? 'end' : 'start', ly: y + 3 };
  });
}

// top "original embeddings" panels
const tw = 92, th = 78, tay = 150;
const top = [
  { ax: 205, label: 'Queries', color: accent,  dots: mk(205, tay, tw, th, layA, accent) },
  { ax: 320, label: 'Keys',    color: accent2, dots: mk(320, tay, tw, th, layB, accent2) },
  { ax: 435, label: 'Values',  color: amber,   dots: mk(435, tay, tw, th, layC, amber) },
];
// per-head panels
const hw = 78, hh = 82, hay = 360;
const head1 = [
  { ax: 65,  label: 'Q', color: accent,  dots: mk(65,  hay, hw, hh, layD, accent) },
  { ax: 160, label: 'K', color: accent2, dots: mk(160, hay, hw, hh, layE, accent2) },
  { ax: 255, label: 'V', color: amber,   dots: mk(255, hay, hw, hh, layF, amber) },
];
const head2 = [
  { ax: 405, label: 'Q', color: accent,  dots: mk(405, hay, hw, hh, layC, accent) },
  { ax: 500, label: 'K', color: accent2, dots: mk(500, hay, hw, hh, layA, accent2) },
  { ax: 595, label: 'V', color: amber,   dots: mk(595, hay, hw, hh, layB, amber) },
];
---

<figure class="mha">
  <svg viewBox="0 0 720 466" role="img" aria-label="Multi-head attention overview" class="mha-svg">
    <defs>
      <marker id="mha-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" class="mha-head" />
      </marker>
    </defs>

    <!-- ===== Original embeddings ===== -->
    <text x="360" y="22" class="mha-title">{L.orig}</text>
    <rect x="170" y="32" width="380" height="122" rx="9" class="mha-dash" />
    {top.map(p => (
      <g>
        <text x={p.ax + tw / 2} y="58" class="mha-sub" style={`fill:${p.color}`}>{p.label}</text>
        <line x1={p.ax} y1={tay} x2={p.ax} y2={tay - th} class="mha-axis" />
        <line x1={p.ax} y1={tay} x2={p.ax + tw} y2={tay} class="mha-axis" />
        {p.dots.map(d => (
          <g>
            <circle cx={d.x} cy={d.y} r="4.5" style={`fill:${d.color}`} />
            <text x={d.lx} y={d.ly} class="mha-dlbl" style={`text-anchor:${d.anchor}`}>{d.t}</text>
          </g>
        ))}
      </g>
    ))}

    <!-- ===== projection arrows (labels kept off the lines) ===== -->
    <line x1="300" y1="154" x2="190" y2="248" class="mha-line" marker-end="url(#mha-arrow)" />
    <line x1="430" y1="154" x2="530" y2="248" class="mha-line" marker-end="url(#mha-arrow)" />
    <text x="150" y="198" class="mha-proj">
      <tspan>W</tspan><tspan baseline-shift="sub" font-size="8">1</tspan><tspan baseline-shift="super" font-size="8">Q</tspan>
      <tspan dx="2">W</tspan><tspan baseline-shift="sub" font-size="8">1</tspan><tspan baseline-shift="super" font-size="8">K</tspan>
      <tspan dx="2">W</tspan><tspan baseline-shift="sub" font-size="8">1</tspan><tspan baseline-shift="super" font-size="8">V</tspan>
    </text>
    <text x="580" y="198" class="mha-proj">
      <tspan>W</tspan><tspan baseline-shift="sub" font-size="8">2</tspan><tspan baseline-shift="super" font-size="8">Q</tspan>
      <tspan dx="2">W</tspan><tspan baseline-shift="sub" font-size="8">2</tspan><tspan baseline-shift="super" font-size="8">K</tspan>
      <tspan dx="2">W</tspan><tspan baseline-shift="sub" font-size="8">2</tspan><tspan baseline-shift="super" font-size="8">V</tspan>
    </text>

    <!-- ===== Head 1 ===== -->
    <text x="248" y="242" class="mha-htitle">{L.head1}</text>
    <rect x="40" y="248" width="300" height="126" rx="9" class="mha-dash" />
    {head1.map(p => (
      <g>
        <text x={p.ax + hw / 2} y="268" class="mha-sub" style={`fill:${p.color}`}>{p.label}</text>
        <line x1={p.ax} y1={hay} x2={p.ax} y2={hay - hh} class="mha-axis" />
        <line x1={p.ax} y1={hay} x2={p.ax + hw} y2={hay} class="mha-axis" />
        {p.dots.map(d => (
          <g>
            <circle cx={d.x} cy={d.y} r="4.5" style={`fill:${d.color}`} />
            <text x={d.lx} y={d.ly} class="mha-dlbl" style={`text-anchor:${d.anchor}`}>{d.t}</text>
          </g>
        ))}
      </g>
    ))}

    <!-- ===== Head 2 ===== -->
    <text x="472" y="242" class="mha-htitle">{L.head2}</text>
    <rect x="380" y="248" width="300" height="126" rx="9" class="mha-dash" />
    {head2.map(p => (
      <g>
        <text x={p.ax + hw / 2} y="268" class="mha-sub" style={`fill:${p.color}`}>{p.label}</text>
        <line x1={p.ax} y1={hay} x2={p.ax} y2={hay - hh} class="mha-axis" />
        <line x1={p.ax} y1={hay} x2={p.ax + hw} y2={hay} class="mha-axis" />
        {p.dots.map(d => (
          <g>
            <circle cx={d.x} cy={d.y} r="4.5" style={`fill:${d.color}`} />
            <text x={d.lx} y={d.ly} class="mha-dlbl" style={`text-anchor:${d.anchor}`}>{d.t}</text>
          </g>
        ))}
      </g>
    ))}

    <!-- ===== concat + output ===== -->
    <line x1="190" y1="374" x2="305" y2="398" class="mha-line" marker-end="url(#mha-arrow)" />
    <line x1="530" y1="374" x2="415" y2="398" class="mha-line" marker-end="url(#mha-arrow)" />
    <rect x="300" y="398" width="120" height="30" rx="8" class="mha-concat" />
    <text x="360" y="417" class="mha-concat-text">
      <tspan>{L.concat} → W</tspan><tspan baseline-shift="super" font-size="8">O</tspan>
    </text>
    <line x1="360" y1="428" x2="360" y2="444" class="mha-line" marker-end="url(#mha-arrow)" />
    <text x="360" y="456" class="mha-out">{L.output}</text>
  </svg>
  <figcaption class="mha-cap">{L.cap}</figcaption>
</figure>

<style>
  .mha { margin: 1.75rem 0; border: 1px solid var(--border); border-radius: 10px; background: var(--bg2); padding: 0.8rem 0 0.4rem; }
  .mha-svg { display: block; width: 100%; max-width: 680px; height: auto; margin: 0 auto; }
  .mha-title { fill: var(--text); font-family: var(--mono); font-size: 12px; font-weight: 600; text-anchor: middle; }
  .mha-dash { fill: none; stroke: var(--border); stroke-width: 1.3; stroke-dasharray: 5 3; }
  .mha-sub { font-family: var(--mono); font-size: 11px; font-weight: 600; text-anchor: middle; }
  .mha-axis { stroke: var(--muted); stroke-width: 1.1; opacity: 0.55; }
  .mha-dlbl { fill: var(--muted); font-family: var(--mono); font-size: 8px; }
  .mha-line { stroke: var(--muted); stroke-width: 1.5; fill: none; }
  .mha-head { fill: var(--muted); }
  .mha-proj { fill: var(--text); font-family: var(--mono); font-size: 11px; text-anchor: middle; }
  .mha-htitle { fill: var(--text); font-family: var(--mono); font-size: 12px; font-weight: 600; text-anchor: middle; }
  .mha-concat { fill: var(--bg); stroke: var(--amber); stroke-width: 1.6; }
  .mha-concat-text { fill: var(--text); font-family: var(--mono); font-size: 11px; text-anchor: middle; }
  .mha-out { fill: var(--muted); font-family: var(--mono); font-size: 10px; text-anchor: middle; }
  .mha-cap { font-size: 0.78rem; color: var(--muted); text-align: center; padding: 0.5rem 1rem 0.6rem; font-style: italic; line-height: 1.5; }
</style>
