---
interface Props {
  lang?: 'vi' | 'en';
}
const { lang = 'vi' } = Astro.props;

const L = lang === 'en'
  ? {
      t1: 'Contrastive alignment', t1sub: 'two encoders, one shared space',
      t2: 'Vision-language model', t2sub: 'vision bolted onto an LLM',
      t3: 'Text-to-image', t3sub: 'text conditions a generator',
      img: 'image', txt: 'text', enc: 'enc', shared: 'shared space',
      venc: 'vision enc', adapter: 'adapter', llm: 'LLM', out: 'answer',
      tenc: 'text enc', diff: 'diffusion', imgout: 'image',
      cap: 'Three recurring patterns. Contrastive alignment (CLIP) trains two encoders so paired image–text land close in one embedding space — built for matching and retrieval. A vision-language model feeds encoded images into an LLM through a small adapter — built for understanding and reasoning. Text-to-image runs the arrow the other way: a text encoder conditions a generative model — built for synthesis.',
    }
  : {
      t1: 'Contrastive alignment', t1sub: 'hai encoder, một không gian chung',
      t2: 'Vision-language model', t2sub: 'gắn vision vào LLM',
      t3: 'Text-to-image', t3sub: 'text điều kiện hóa generator',
      img: 'ảnh', txt: 'text', enc: 'enc', shared: 'không gian chung',
      venc: 'vision enc', adapter: 'adapter', llm: 'LLM', out: 'câu trả lời',
      tenc: 'text enc', diff: 'diffusion', imgout: 'ảnh',
      cap: 'Ba pattern lặp đi lặp lại. Contrastive alignment (CLIP) train hai encoder sao cho cặp ảnh–text rơi gần nhau trong một không gian embedding — sinh ra để match và retrieval. Vision-language model đưa ảnh đã encode vào LLM qua một adapter nhỏ — sinh ra để hiểu và suy luận. Text-to-image chạy mũi tên theo chiều ngược lại: text encoder điều kiện hóa một generative model — sinh ra để tổng hợp.',
    };
---

<figure class="mmp" data-lang={lang}>
  <svg viewBox="0 0 760 250" role="img" aria-label="Three multimodal design patterns" class="mmp-svg">
    <defs>
      <marker id="mmp-a" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" class="mmp-head" />
      </marker>
    </defs>

    <line x1="253" y1="16" x2="253" y2="212" class="mmp-div" />
    <line x1="506" y1="16" x2="506" y2="212" class="mmp-div" />

    <!-- ===== Panel 1: contrastive ===== -->
    <text x="126" y="34" class="mmp-title">{L.t1}</text>
    <rect x="26" y="62" width="52" height="30" rx="6" class="mmp-in" /><text x="52" y="81" class="mmp-nt">{L.img}</text>
    <rect x="26" y="130" width="52" height="30" rx="6" class="mmp-in2" /><text x="52" y="149" class="mmp-nt">{L.txt}</text>
    <line x1="78" y1="77" x2="98" y2="77" class="mmp-line" marker-end="url(#mmp-a)" />
    <line x1="78" y1="145" x2="98" y2="145" class="mmp-line" marker-end="url(#mmp-a)" />
    <rect x="100" y="63" width="44" height="28" rx="6" class="mmp-box" /><text x="122" y="81" class="mmp-bt">{L.enc}</text>
    <rect x="100" y="131" width="44" height="28" rx="6" class="mmp-box" /><text x="122" y="149" class="mmp-bt">{L.enc}</text>
    <line x1="144" y1="77" x2="170" y2="90" class="mmp-line" marker-end="url(#mmp-a)" />
    <line x1="144" y1="145" x2="170" y2="132" class="mmp-line" marker-end="url(#mmp-a)" />
    <ellipse cx="203" cy="111" rx="42" ry="34" class="mmp-space" />
    <circle cx="192" cy="103" r="4" class="mmp-dot1" />
    <path d="M199,116 l5,-8 l5,8 z" class="mmp-dot2" />
    <circle cx="215" cy="99" r="4" class="mmp-dot1" />
    <path d="M186,124 l5,-8 l5,8 z" class="mmp-dot2" />
    <text x="203" y="164" class="mmp-mini">{L.shared}</text>
    <text x="126" y="196" class="mmp-sub">{L.t1sub}</text>

    <!-- ===== Panel 2: VLM ===== -->
    <text x="380" y="34" class="mmp-title">{L.t2}</text>
    <rect x="272" y="62" width="46" height="30" rx="6" class="mmp-in" /><text x="295" y="81" class="mmp-nt">{L.img}</text>
    <line x1="318" y1="77" x2="334" y2="77" class="mmp-line" marker-end="url(#mmp-a)" />
    <rect x="336" y="63" width="66" height="28" rx="6" class="mmp-box" /><text x="369" y="81" class="mmp-bt">{L.venc}</text>
    <line x1="402" y1="77" x2="418" y2="77" class="mmp-line" marker-end="url(#mmp-a)" />
    <rect x="420" y="63" width="58" height="28" rx="6" class="mmp-adapter" /><text x="449" y="81" class="mmp-bt">{L.adapter}</text>
    <rect x="272" y="130" width="46" height="30" rx="6" class="mmp-in2" /><text x="295" y="149" class="mmp-nt">{L.txt}</text>
    <line x1="318" y1="145" x2="356" y2="145" class="mmp-line" marker-end="url(#mmp-a)" />
    <line x1="449" y1="91" x2="404" y2="128" class="mmp-line" marker-end="url(#mmp-a)" />
    <rect x="358" y="131" width="76" height="30" rx="7" class="mmp-llm" /><text x="396" y="150" class="mmp-bt">{L.llm}</text>
    <line x1="434" y1="145" x2="474" y2="145" class="mmp-line" marker-end="url(#mmp-a)" />
    <text x="474" y="136" class="mmp-mini" text-anchor="end">{L.out}</text>
    <text x="380" y="196" class="mmp-sub">{L.t2sub}</text>

    <!-- ===== Panel 3: text-to-image ===== -->
    <text x="632" y="34" class="mmp-title">{L.t3}</text>
    <rect x="528" y="96" width="46" height="30" rx="6" class="mmp-in2" /><text x="551" y="115" class="mmp-nt">{L.txt}</text>
    <line x1="574" y1="111" x2="590" y2="111" class="mmp-line" marker-end="url(#mmp-a)" />
    <rect x="592" y="97" width="62" height="28" rx="6" class="mmp-box" /><text x="623" y="115" class="mmp-bt">{L.tenc}</text>
    <line x1="654" y1="111" x2="670" y2="111" class="mmp-line" marker-end="url(#mmp-a)" />
    <rect x="672" y="95" width="66" height="32" rx="7" class="mmp-gen" /><text x="705" y="115" class="mmp-bt">{L.diff}</text>
    <line x1="705" y1="127" x2="705" y2="148" class="mmp-line" marker-end="url(#mmp-a)" />
    <rect x="683" y="150" width="44" height="30" rx="6" class="mmp-in" /><text x="705" y="169" class="mmp-nt">{L.imgout}</text>
    <text x="632" y="196" class="mmp-sub">{L.t3sub}</text>
  </svg>
  <figcaption class="mmp-cap">{L.cap}</figcaption>
</figure>

<style>
  .mmp {
    margin: 1.75rem 0;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--bg2);
    padding: 0.75rem 0 0.2rem;
  }
  .mmp-svg { display: block; width: 100%; max-width: 800px; height: auto; margin: 0 auto; }
  .mmp-div { stroke: var(--border); stroke-width: 1.1; stroke-dasharray: 4 4; }
  .mmp-title { fill: var(--text); font-family: var(--mono); font-size: 12.5px; font-weight: 600; text-anchor: middle; }
  .mmp-sub { fill: var(--muted); font-family: var(--mono); font-size: 10px; text-anchor: middle; }
  .mmp-in { fill: var(--accent); fill-opacity: 0.25; stroke: var(--accent); stroke-width: 1.5; }
  .mmp-in2 { fill: var(--amber); fill-opacity: 0.22; stroke: var(--amber); stroke-width: 1.5; }
  .mmp-box { fill: var(--bg); stroke: var(--muted); stroke-width: 1.6; }
  .mmp-adapter { fill: var(--bg); stroke: var(--danger); stroke-width: 1.6; stroke-dasharray: 4 3; }
  .mmp-llm { fill: var(--bg); stroke: var(--accent2); stroke-width: 2; }
  .mmp-gen { fill: var(--bg); stroke: var(--accent2); stroke-width: 2; }
  .mmp-space { fill: var(--accent2); fill-opacity: 0.10; stroke: var(--accent2); stroke-width: 1.5; }
  .mmp-dot1 { fill: var(--accent); }
  .mmp-dot2 { fill: var(--amber); }
  .mmp-nt { fill: var(--text); font-family: var(--mono); font-size: 10.5px; text-anchor: middle; }
  .mmp-bt { fill: var(--text); font-family: var(--mono); font-size: 10.5px; text-anchor: middle; }
  .mmp-mini { fill: var(--muted); font-family: var(--mono); font-size: 9.5px; text-anchor: middle; }
  .mmp-line { stroke: var(--text); stroke-width: 1.4; fill: none; }
  .mmp-head { fill: var(--text); }
  .mmp-cap {
    font-size: 0.78rem;
    color: var(--muted);
    text-align: center;
    padding: 0.5rem 1rem 0.65rem;
    font-style: italic;
    line-height: 1.5;
  }
</style>
