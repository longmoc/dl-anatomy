---
interface Props {
  lang?: 'vi' | 'en';
}
const { lang = 'vi' } = Astro.props;

const L = lang === 'en'
  ? {
      title: 'Likelihood, cross-entropy, and KL: the same mismatch seen three ways',
      data: 'data distribution p',
      model: 'model distribution qθ',
      likelihood: 'likelihood',
      ce: 'cross-entropy',
      kl: 'KL divergence',
      nll: 'NLL: how surprising is the observed data?',
      coding: 'CE: how many nats/bits if q encodes p?',
      mismatch: 'KL: how much extra cost from using q instead of p?',
      cap: 'In supervised classification, the true distribution is often a one-hot label, so cross-entropy reduces to negative log-likelihood. In distribution form, minimizing cross-entropy is equivalent to minimizing KL divergence because H(p) is fixed.',
    }
  : {
      title: 'Likelihood, cross-entropy và KL: cùng một độ lệch nhìn từ ba phía',
      data: 'phân phối dữ liệu p',
      model: 'phân phối model qθ',
      likelihood: 'likelihood',
      ce: 'cross-entropy',
      kl: 'KL divergence',
      nll: 'NLL: dữ liệu quan sát bất ngờ đến mức nào?',
      coding: 'CE: dùng q mã hóa p tốn bao nhiêu nats/bits?',
      mismatch: 'KL: dùng q thay p lãng phí thêm bao nhiêu?',
      cap: 'Trong classification supervised, phân phối thật thường là label one-hot, nên cross-entropy rút về negative log-likelihood. Ở dạng phân phối, minimize cross-entropy tương đương minimize KL vì H(p) cố định.',
    };

const legend = [
  { c: 'var(--accent)', t: L.nll },
  { c: 'var(--amber)', t: L.coding },
  { c: 'var(--accent2)', t: L.mismatch },
];
---

<figure class="pdd" data-lang={lang}>
  <svg viewBox="0 0 720 300" role="img" aria-label="Likelihood cross-entropy KL diagram" class="pdd-svg">
    <defs>
      <marker id="pdd-blue" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" style="fill:var(--accent)" />
      </marker>
      <marker id="pdd-amber" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" style="fill:var(--amber)" />
      </marker>
      <marker id="pdd-green" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" style="fill:var(--accent2)" />
      </marker>
    </defs>

    <text x="360" y="26" class="pdd-title">{L.title}</text>

    <!-- likelihood arc (top) -->
    <path d="M149,118 C260,82 460,82 571,118" class="pdd-arc-l" fill="none" marker-end="url(#pdd-blue)" />
    <text x="360" y="80" class="pdd-mid" style="fill:var(--accent)">{L.likelihood}</text>

    <!-- KL line (middle) -->
    <line x1="228" y1="147" x2="492" y2="147" class="pdd-arc-k" marker-end="url(#pdd-green)" />
    <text x="360" y="139" class="pdd-mid" style="fill:var(--accent2)">{L.kl}</text>

    <!-- cross-entropy arc (bottom) -->
    <path d="M149,176 C260,206 460,206 571,176" class="pdd-arc-c" fill="none" marker-end="url(#pdd-amber)" />
    <text x="360" y="216" class="pdd-mid" style="fill:var(--amber)">{L.ce}</text>

    <!-- distributions -->
    <rect x="70" y="118" width="158" height="58" rx="10" class="pdd-data" />
    <text x="149" y="143" class="pdd-label">p(x, y)</text>
    <text x="149" y="163" class="pdd-small">{L.data}</text>

    <rect x="492" y="118" width="158" height="58" rx="10" class="pdd-model" />
    <text x="571" y="143" class="pdd-label">qθ(y|x)</text>
    <text x="571" y="163" class="pdd-small">{L.model}</text>

    <!-- legend (full-width lines, no boxes to overflow) -->
    {legend.map((g, i) => (
      <g>
        <circle cx="76" cy={234 + i * 22} r="4.5" style={`fill:${g.c}`} />
        <text x="90" y={238 + i * 22} class="pdd-leg">{g.t}</text>
      </g>
    ))}
  </svg>
  <figcaption class="pdd-cap">{L.cap}</figcaption>
</figure>

<style>
  .pdd {
    margin: 1.75rem 0;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--bg2);
    padding: 0.75rem 0 0.2rem;
  }
  .pdd-svg { display: block; width: 100%; max-width: 780px; height: auto; margin: 0 auto; }
  .pdd-title { fill: var(--text); font-family: var(--mono); font-size: 12.8px; font-weight: 600; text-anchor: middle; }
  .pdd-data { fill: var(--bg); stroke: var(--accent); stroke-width: 1.8; }
  .pdd-model { fill: var(--bg); stroke: var(--accent2); stroke-width: 1.8; }
  .pdd-arc-l { stroke: var(--accent); stroke-width: 1.7; }
  .pdd-arc-k { stroke: var(--accent2); stroke-width: 1.8; }
  .pdd-arc-c { stroke: var(--amber); stroke-width: 1.7; }
  .pdd-label, .pdd-small, .pdd-mid {
    font-family: var(--mono);
    text-anchor: middle;
  }
  .pdd-label { fill: var(--text); font-size: 13px; font-weight: 700; }
  .pdd-small { fill: var(--muted); font-size: 10px; }
  .pdd-mid { font-size: 11.5px; font-weight: 600; }
  .pdd-leg { fill: var(--text); font-family: var(--mono); font-size: 11px; text-anchor: start; }
  .pdd-cap {
    font-size: 0.78rem;
    color: var(--muted);
    text-align: center;
    padding: 0.5rem 1rem 0.65rem;
    font-style: italic;
    line-height: 1.5;
  }
</style>
