---
interface Props {
  lang?: 'vi' | 'en';
}
const { lang = 'vi' } = Astro.props;

const L = lang === 'en'
  ? {
      title: 'Mamba selective scan',
      step: '(step / forget)',
      write: '(write)',
      read: '(read)',
      state: 'state hₜ',
      cap: 'In Mamba the read/write parameters are produced by each token: Δₜ controls how fast the state changes (forget), Bₜ how the token is written in, Cₜ what is read out. Every token decides what to write, keep, and read.',
    }
  : {
      title: 'Mamba selective scan',
      step: '(bước / quên)',
      write: '(ghi)',
      read: '(đọc)',
      state: 'state hₜ',
      cap: 'Trong Mamba, tham số đọc/ghi do chính mỗi token sinh ra: Δₜ quyết định state đổi nhanh hay chậm (quên), Bₜ cách token được ghi vào, Cₜ phần nào được đọc ra. Mỗi token tự quyết ghi gì, giữ gì, đọc gì.',
    };
---

<figure class="ssc">
  <svg viewBox="0 0 560 212" role="img" aria-label="Mamba selective scan" class="ssc-svg">
    <defs>
      <marker id="ssc-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" class="ssc-head" />
      </marker>
    </defs>

    <text x="280" y="24" class="ssc-title">{L.title}</text>

    <!-- input token -->
    <circle cx="54" cy="117" r="14" class="ssc-tok" />
    <text x="54" y="121" class="ssc-small">xₜ</text>

    <!-- fan-out to the three input-dependent params -->
    <line x1="68" y1="113" x2="122" y2="71" class="ssc-line" marker-end="url(#ssc-arrow)" />
    <line x1="68" y1="117" x2="122" y2="117" class="ssc-line" marker-end="url(#ssc-arrow)" />
    <line x1="68" y1="121" x2="122" y2="163" class="ssc-line" marker-end="url(#ssc-arrow)" />

    <rect x="124" y="54" width="80" height="34" rx="8" class="ssc-pill" />
    <text x="164" y="70" class="ssc-pill-sym">Δₜ</text>
    <text x="164" y="82" class="ssc-pill-sub">{L.step}</text>

    <rect x="124" y="100" width="80" height="34" rx="8" class="ssc-pill" />
    <text x="164" y="116" class="ssc-pill-sym">Bₜ</text>
    <text x="164" y="128" class="ssc-pill-sub">{L.write}</text>

    <rect x="124" y="146" width="80" height="34" rx="8" class="ssc-pill" />
    <text x="164" y="162" class="ssc-pill-sym">Cₜ</text>
    <text x="164" y="174" class="ssc-pill-sub">{L.read}</text>

    <!-- state -->
    <rect x="300" y="94" width="98" height="46" rx="9" class="ssc-state" />
    <text x="349" y="121" class="ssc-state-text">{L.state}</text>

    <!-- Δ and B write into state -->
    <line x1="204" y1="71" x2="300" y2="104" class="ssc-line" marker-end="url(#ssc-arrow)" />
    <line x1="204" y1="117" x2="300" y2="117" class="ssc-line" marker-end="url(#ssc-arrow)" />

    <!-- read out to output -->
    <line x1="398" y1="117" x2="494" y2="117" class="ssc-line" marker-end="url(#ssc-arrow)" />
    <circle cx="510" cy="117" r="14" class="ssc-out" />
    <text x="510" y="121" class="ssc-small">yₜ</text>
    <!-- C controls the read: arrow lands on the read line -->
    <path d="M204,163 C334,172 438,150 450,120" class="ssc-line-c" fill="none" marker-end="url(#ssc-arrow)" />
  </svg>
  <figcaption class="ssc-cap">{L.cap}</figcaption>
</figure>

<style>
  .ssc { margin: 1.75rem 0; border: 1px solid var(--border); border-radius: 10px; background: var(--bg2); padding: 0.8rem 0 0.25rem; }
  .ssc-svg { display: block; width: 100%; max-width: 640px; height: auto; margin: 0 auto; }
  .ssc-title { fill: var(--text); font-family: var(--mono); font-size: 13.5px; font-weight: 600; text-anchor: middle; }
  .ssc-tok { fill: var(--bg); stroke: var(--amber); stroke-width: 1.6; }
  .ssc-out { fill: var(--bg); stroke: var(--accent2); stroke-width: 1.6; }
  .ssc-state { fill: var(--bg); stroke: var(--accent); stroke-width: 1.7; }
  .ssc-pill { fill: var(--bg); stroke: var(--accent2); stroke-width: 1.5; }
  .ssc-pill-sym { fill: var(--text); font-family: var(--mono); font-size: 13px; font-weight: 600; text-anchor: middle; }
  .ssc-pill-sub { fill: var(--muted); font-family: var(--mono); font-size: 10px; text-anchor: middle; }
  .ssc-small { fill: var(--text); font-family: var(--mono); font-size: 11.5px; text-anchor: middle; }
  .ssc-state-text { fill: var(--text); font-family: var(--mono); font-size: 12.5px; font-weight: 600; text-anchor: middle; }
  .ssc-line { stroke: var(--muted); stroke-width: 1.5; }
  .ssc-line-c { stroke: var(--accent2); stroke-width: 1.4; stroke-dasharray: 4 3; opacity: 0.8; }
  .ssc-head { fill: var(--muted); }
  .ssc-cap { font-size: 0.78rem; color: var(--muted); text-align: center; padding: 0.5rem 1rem 0.65rem; font-style: italic; line-height: 1.5; }
</style>
