---
interface Props {
  lang?: 'vi' | 'en';
}
const { lang = 'vi' } = Astro.props;

const L = lang === 'en'
  ? {
      out: 'output',
      inp: 'Inputs',
      emb: 'Input Embedding',
      pe: ['positional', 'encoding'],
      res: 'residual connection',
      cap: 'A Transformer block (encoder-style): the input sequence is embedded and added to positional encoding, then flows through Multi-Head Attention → Add & Norm → Feed-Forward → Add & Norm. Each sub-layer has a residual connection (red) that adds its input back to its output before normalization. The whole block is stacked N times.',
    }
  : {
      out: 'output',
      inp: 'Đầu vào',
      emb: 'Input Embedding',
      pe: ['positional', 'encoding'],
      res: 'residual connection',
      cap: 'Một Transformer block (kiểu encoder): chuỗi đầu vào được embedding và cộng positional encoding, rồi đi qua Multi-Head Attention → Add & Norm → Feed-Forward → Add & Norm. Mỗi sub-layer có một residual connection (đường đỏ) cộng đầu vào vào đầu ra trước khi chuẩn hoá. Cả block được xếp chồng N lần.',
    };
---

<figure class="tbd">
  <svg viewBox="0 120 460 430" role="img" aria-label="Transformer block" class="tbd-svg">
    <defs>
      <marker id="tbd-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6.5" markerHeight="6.5" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" class="tbd-head" />
      </marker>
      <marker id="tbd-red" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6.5" markerHeight="6.5" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" class="tbd-redhead" />
      </marker>
    </defs>

    <!-- output (top) -->
    <text x="170" y="128" class="tbd-io">{L.out}</text>
    <line x1="170" y1="186" x2="170" y2="138" class="tbd-line" marker-end="url(#tbd-arrow)" />

    <!-- repeated-block container -->
    <rect x="70" y="178" width="200" height="226" rx="12" class="tbd-container" />
    <text x="50" y="296" class="tbd-nx">N×</text>

    <!-- inner main path arrows -->
    <line x1="170" y1="430" x2="170" y2="388" class="tbd-line" marker-end="url(#tbd-arrow)" />
    <line x1="170" y1="344" x2="170" y2="332" class="tbd-line" marker-end="url(#tbd-arrow)" />
    <line x1="170" y1="300" x2="170" y2="274" class="tbd-line" marker-end="url(#tbd-arrow)" />
    <line x1="170" y1="230" x2="170" y2="218" class="tbd-line" marker-end="url(#tbd-arrow)" />

    <!-- inner boxes -->
    <rect x="85" y="344" width="170" height="42" rx="7" class="tbd-box tbd-mha" />
    <text x="170" y="370" class="tbd-blk">Multi-Head Attention</text>

    <rect x="85" y="300" width="170" height="30" rx="7" class="tbd-box tbd-norm" />
    <text x="170" y="320" class="tbd-blk">Add &amp; Norm</text>

    <rect x="85" y="230" width="170" height="42" rx="7" class="tbd-box tbd-ff" />
    <text x="170" y="256" class="tbd-blk">Feed Forward</text>

    <rect x="85" y="186" width="170" height="30" rx="7" class="tbd-box tbd-norm" />
    <text x="170" y="206" class="tbd-blk">Add &amp; Norm</text>

    <!-- residual connection 1: bypass Multi-Head Attention -->
    <path d="M170,396 H290 V315 H257" class="tbd-res" marker-end="url(#tbd-red)" />
    <circle cx="170" cy="396" r="3.4" class="tbd-tap" />
    <text x="298" y="370" class="tbd-reslbl">{L.res}</text>

    <!-- residual connection 2: bypass Feed Forward -->
    <path d="M170,288 H290 V201 H257" class="tbd-res" marker-end="url(#tbd-red)" />
    <circle cx="170" cy="288" r="3.4" class="tbd-tap" />
    <text x="298" y="238" class="tbd-reslbl">{L.res}</text>

    <!-- embedding + positional encoding -->
    <circle cx="170" cy="442" r="12" class="tbd-plus" />
    <line x1="161" y1="442" x2="179" y2="442" class="tbd-plusline" />
    <line x1="170" y1="433" x2="170" y2="451" class="tbd-plusline" />
    <text x="189" y="438" class="tbd-pe">{L.pe[0]}</text>
    <text x="189" y="451" class="tbd-pe">{L.pe[1]}</text>

    <line x1="170" y1="474" x2="170" y2="456" class="tbd-line" marker-end="url(#tbd-arrow)" />
    <rect x="85" y="474" width="170" height="34" rx="7" class="tbd-box tbd-emb" />
    <text x="170" y="496" class="tbd-blk">{L.emb}</text>

    <line x1="170" y1="532" x2="170" y2="510" class="tbd-line" marker-end="url(#tbd-arrow)" />
    <text x="170" y="544" class="tbd-io">{L.inp}</text>
  </svg>
  <figcaption class="tbd-cap">{L.cap}</figcaption>
</figure>

<style>
  .tbd { margin: 1.75rem 0; border: 1px solid var(--border); border-radius: 10px; background: var(--bg2); padding: 0.8rem 0 0.4rem; }
  .tbd-svg { display: block; width: 100%; max-width: 440px; height: auto; margin: 0 auto; }
  .tbd-line { stroke: var(--text); stroke-width: 1.8; fill: none; }
  .tbd-head { fill: var(--text); }
  .tbd-container { fill: none; stroke: var(--border); stroke-width: 1.4; stroke-dasharray: 5 4; }
  .tbd-nx { fill: var(--muted); font-family: var(--mono); font-size: 15px; font-weight: 600; text-anchor: middle; }
  .tbd-box { fill: var(--bg); stroke-width: 2; }
  .tbd-mha { stroke: var(--amber); }
  .tbd-norm { stroke: var(--accent2); }
  .tbd-ff { stroke: var(--accent); }
  .tbd-emb { stroke: var(--muted); }
  .tbd-blk { fill: var(--text); font-family: var(--mono); font-size: 13px; text-anchor: middle; }
  .tbd-res { stroke: var(--danger); stroke-width: 2; fill: none; }
  .tbd-redhead { fill: var(--danger); }
  .tbd-tap { fill: var(--danger); }
  .tbd-reslbl { fill: var(--danger); font-family: var(--mono); font-size: 11px; text-anchor: start; }
  .tbd-plus { fill: var(--bg); stroke: var(--text); stroke-width: 1.6; }
  .tbd-plusline { stroke: var(--text); stroke-width: 1.5; }
  .tbd-pe { fill: var(--muted); font-family: var(--mono); font-size: 10.5px; text-anchor: start; }
  .tbd-io { fill: var(--text); font-family: var(--mono); font-size: 14.5px; text-anchor: middle; }
  .tbd-cap { font-size: 0.78rem; color: var(--muted); text-align: center; padding: 0.5rem 1rem 0.6rem; font-style: italic; line-height: 1.5; }
</style>
