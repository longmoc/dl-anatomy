---
interface Props {
  lang?: 'vi' | 'en';
}
const { lang = 'vi' } = Astro.props;

const L = lang === 'en'
  ? {
      out: 'output',
      inp: 'Inputs',
      emb: 'Input Embedding',
      pe: ['positional', 'encoding'],
      res: 'residual connection',
      cap: 'A Transformer block (encoder-style): the input sequence is embedded and added to positional encoding, then flows through Multi-Head Attention → Add & Norm → Feed-Forward → Add & Norm. Each sub-layer has a residual connection (red) that adds its input back to its output before normalization. The whole block is stacked N times.',
    }
  : {
      out: 'output',
      inp: 'Đầu vào',
      emb: 'Input Embedding',
      pe: ['positional', 'encoding'],
      res: 'residual connection',
      cap: 'Một Transformer block (kiểu encoder): chuỗi đầu vào được embedding và cộng positional encoding, rồi đi qua Multi-Head Attention → Add & Norm → Feed-Forward → Add & Norm. Mỗi sub-layer có một residual connection (đường đỏ) cộng đầu vào vào đầu ra trước khi chuẩn hoá. Cả block được xếp chồng N lần.',
    };
---

<figure class="tbd">
  <svg viewBox="0 0 420 540" role="img" aria-label="Transformer block" class="tbd-svg">
    <defs>
      <marker id="tbd-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6.5" markerHeight="6.5" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" class="tbd-head" />
      </marker>
      <marker id="tbd-red" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6.5" markerHeight="6.5" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" class="tbd-redhead" />
      </marker>
    </defs>

    <!-- output (top) -->
    <text x="170" y="16" class="tbd-io">{L.out}</text>
    <line x1="170" y1="204" x2="170" y2="24" class="tbd-line" marker-end="url(#tbd-arrow)" />

    <!-- repeated-block container -->
    <rect x="75" y="188" width="200" height="218" rx="12" class="tbd-container" />
    <text x="58" y="300" class="tbd-nx">N×</text>

    <!-- inner main path arrows -->
    <line x1="170" y1="406" x2="170" y2="386" class="tbd-line" marker-end="url(#tbd-arrow)" />
    <line x1="170" y1="350" x2="170" y2="340" class="tbd-line" marker-end="url(#tbd-arrow)" />
    <line x1="170" y1="312" x2="170" y2="280" class="tbd-line" marker-end="url(#tbd-arrow)" />
    <line x1="170" y1="244" x2="170" y2="232" class="tbd-line" marker-end="url(#tbd-arrow)" />

    <!-- inner boxes -->
    <rect x="95" y="350" width="150" height="36" rx="6" class="tbd-box tbd-mha" />
    <text x="170" y="372" class="tbd-blk">Multi-Head Attention</text>

    <rect x="95" y="312" width="150" height="26" rx="6" class="tbd-box tbd-norm" />
    <text x="170" y="329" class="tbd-blk">Add &amp; Norm</text>

    <rect x="95" y="244" width="150" height="36" rx="6" class="tbd-box tbd-ff" />
    <text x="170" y="266" class="tbd-blk">Feed Forward</text>

    <rect x="95" y="204" width="150" height="26" rx="6" class="tbd-box tbd-norm" />
    <text x="170" y="221" class="tbd-blk">Add &amp; Norm</text>

    <!-- residual connection 1: bypass Multi-Head Attention -->
    <path d="M170,398 H255 V325 H248" class="tbd-res" marker-end="url(#tbd-red)" />
    <circle cx="170" cy="398" r="3" class="tbd-tap" />
    <text x="262" y="372" class="tbd-reslbl">{L.res}</text>

    <!-- residual connection 2: bypass Feed Forward -->
    <path d="M170,300 H268 V217 H248" class="tbd-res" marker-end="url(#tbd-red)" />
    <circle cx="170" cy="300" r="3" class="tbd-tap" />
    <text x="275" y="250" class="tbd-reslbl">{L.res}</text>

    <!-- embedding + positional encoding -->
    <line x1="170" y1="429" x2="170" y2="408" class="tbd-line" marker-end="url(#tbd-arrow)" />
    <circle cx="170" cy="440" r="11" class="tbd-plus" />
    <line x1="163" y1="440" x2="177" y2="440" class="tbd-plusline" />
    <line x1="170" y1="433" x2="170" y2="447" class="tbd-plusline" />
    <text x="187" y="437" class="tbd-pe">{L.pe[0]}</text>
    <text x="187" y="448" class="tbd-pe">{L.pe[1]}</text>

    <line x1="170" y1="470" x2="170" y2="453" class="tbd-line" marker-end="url(#tbd-arrow)" />
    <rect x="95" y="470" width="150" height="30" rx="6" class="tbd-box tbd-emb" />
    <text x="170" y="489" class="tbd-blk">{L.emb}</text>

    <line x1="170" y1="518" x2="170" y2="502" class="tbd-line" marker-end="url(#tbd-arrow)" />
    <text x="170" y="532" class="tbd-io">{L.inp}</text>
  </svg>
  <figcaption class="tbd-cap">{L.cap}</figcaption>
</figure>

<style>
  .tbd { margin: 1.75rem 0; border: 1px solid var(--border); border-radius: 10px; background: var(--bg2); padding: 0.8rem 0 0.4rem; }
  .tbd-svg { display: block; width: 100%; max-width: 360px; height: auto; margin: 0 auto; }
  .tbd-line { stroke: var(--text); stroke-width: 1.6; fill: none; }
  .tbd-head { fill: var(--text); }
  .tbd-container { fill: none; stroke: var(--border); stroke-width: 1.3; stroke-dasharray: 5 4; }
  .tbd-nx { fill: var(--muted); font-family: var(--mono); font-size: 13px; font-weight: 600; text-anchor: middle; }
  .tbd-box { fill: var(--bg); stroke-width: 1.8; }
  .tbd-mha { stroke: var(--amber); }
  .tbd-norm { stroke: var(--accent2); }
  .tbd-ff { stroke: var(--accent); }
  .tbd-emb { stroke: var(--muted); }
  .tbd-blk { fill: var(--text); font-family: var(--mono); font-size: 11px; text-anchor: middle; }
  .tbd-res { stroke: var(--danger); stroke-width: 1.8; fill: none; }
  .tbd-redhead { fill: var(--danger); }
  .tbd-tap { fill: var(--danger); }
  .tbd-reslbl { fill: var(--danger); font-family: var(--mono); font-size: 9.5px; text-anchor: start; }
  .tbd-plus { fill: var(--bg); stroke: var(--text); stroke-width: 1.5; }
  .tbd-plusline { stroke: var(--text); stroke-width: 1.4; }
  .tbd-pe { fill: var(--muted); font-family: var(--mono); font-size: 9px; text-anchor: start; }
  .tbd-io { fill: var(--text); font-family: var(--mono); font-size: 12px; text-anchor: middle; }
  .tbd-cap { font-size: 0.78rem; color: var(--muted); text-align: center; padding: 0.5rem 1rem 0.6rem; font-style: italic; line-height: 1.5; }
</style>
