---
interface Props {
  lang?: 'vi' | 'en';
}
const { lang = 'vi' } = Astro.props;

const L = lang === 'en'
  ? {
      title: 'Statistical learning: from population risk to learned model',
      population: 'population distribution',
      train: 'finite training set',
      erm: 'empirical risk minimization',
      model: 'selected function',
      test: 'unseen data',
      gap: 'generalization gap',
      popMath: 'p_data(x,y)',
      trainMath: 'D = {(xi, yi)}',
      ermMath: 'min R̂(f)',
      modelMath: 'f̂',
      testMath: 'R(f̂)',
      cap: 'The true risk is an expectation over the data distribution, but training only sees a finite dataset. Statistical learning studies when minimizing empirical risk produces a function that also has low risk on unseen data.',
    }
  : {
      title: 'Statistical learning: từ population risk đến model đã học',
      population: 'phân phối dữ liệu thật',
      train: 'train set hữu hạn',
      erm: 'minimize empirical risk',
      model: 'hàm được chọn',
      test: 'dữ liệu chưa thấy',
      gap: 'generalization gap',
      popMath: 'p_data(x,y)',
      trainMath: 'D = {(xi, yi)}',
      ermMath: 'min R̂(f)',
      modelMath: 'f̂',
      testMath: 'R(f̂)',
      cap: 'True risk là kỳ vọng trên phân phối dữ liệu thật, nhưng training chỉ thấy một dataset hữu hạn. Statistical learning hỏi khi nào minimize empirical risk tạo ra một hàm cũng có risk thấp trên dữ liệu chưa thấy.',
    };
---

<figure class="sld" data-lang={lang}>
  <svg viewBox="0 0 780 318" role="img" aria-label="Statistical learning diagram" class="sld-svg">
    <defs>
      <marker id="sld-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" class="sld-head" />
      </marker>
      <marker id="sld-arrow2" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" class="sld-head2" />
      </marker>
    </defs>

    <text x="390" y="27" class="sld-title">{L.title}</text>

    <rect x="42" y="82" width="145" height="74" rx="11" class="sld-pop" />
    <text x="114.5" y="110" class="sld-label">{L.popMath}</text>
    <text x="114.5" y="132" class="sld-small">{L.population}</text>

    <line x1="187" y1="119" x2="255" y2="119" class="sld-line" marker-end="url(#sld-arrow)" />

    <rect x="256" y="82" width="145" height="74" rx="11" class="sld-train" />
    <text x="328.5" y="110" class="sld-label">{L.trainMath}</text>
    <text x="328.5" y="132" class="sld-small">{L.train}</text>

    <line x1="401" y1="119" x2="469" y2="119" class="sld-line" marker-end="url(#sld-arrow)" />

    <rect x="470" y="82" width="145" height="74" rx="11" class="sld-erm" />
    <text x="542.5" y="110" class="sld-label">{L.ermMath}</text>
    <text x="542.5" y="132" class="sld-small">{L.erm}</text>

    <line x1="542.5" y1="156" x2="542.5" y2="202" class="sld-line2" marker-end="url(#sld-arrow2)" />

    <rect x="470" y="204" width="145" height="72" rx="11" class="sld-model" />
    <text x="542.5" y="232" class="sld-label">{L.modelMath}</text>
    <text x="542.5" y="254" class="sld-small">{L.model}</text>

    <path d="M114,156 C126,236 300,252 470,240" class="sld-test-line" fill="none" marker-end="url(#sld-arrow)" />

    <rect x="42" y="204" width="145" height="72" rx="11" class="sld-test" />
    <text x="114.5" y="232" class="sld-label">{L.testMath}</text>
    <text x="114.5" y="254" class="sld-small">{L.test}</text>

    <line x1="187" y1="240" x2="470" y2="240" class="sld-gap" />
    <text x="328.5" y="230" class="sld-gap-label">{L.gap}</text>
  </svg>
  <figcaption class="sld-cap">{L.cap}</figcaption>
</figure>

<style>
  .sld {
    margin: 1.75rem 0;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--bg2);
    padding: 0.75rem 0 0.2rem;
  }
  .sld-svg { display: block; width: 100%; max-width: 840px; height: auto; margin: 0 auto; }
  .sld-title { fill: var(--text); font-family: var(--mono); font-size: 13px; font-weight: 600; text-anchor: middle; }
  .sld-pop, .sld-train, .sld-erm, .sld-model, .sld-test { fill: var(--bg); stroke-width: 1.8; }
  .sld-pop { stroke: var(--accent); }
  .sld-train { stroke: var(--amber); }
  .sld-erm { stroke: var(--muted); }
  .sld-model { stroke: var(--accent2); }
  .sld-test { stroke: var(--accent); stroke-dasharray: 5 4; }
  .sld-label, .sld-small, .sld-gap-label {
    font-family: var(--mono);
    text-anchor: middle;
  }
  .sld-label { fill: var(--text); font-size: 12.5px; font-weight: 700; }
  .sld-small { fill: var(--muted); font-size: 9.5px; }
  .sld-line { stroke: var(--muted); stroke-width: 1.6; }
  .sld-line2 { stroke: var(--accent2); stroke-width: 1.7; }
  .sld-head { fill: var(--muted); }
  .sld-head2 { fill: var(--accent2); }
  .sld-test-line { stroke: var(--accent); stroke-width: 1.5; stroke-dasharray: 5 4; }
  .sld-gap { stroke: var(--danger); stroke-width: 1.5; stroke-dasharray: 4 4; }
  .sld-gap-label { fill: var(--danger); font-size: 10.5px; font-weight: 600; }
  .sld-cap {
    font-size: 0.78rem;
    color: var(--muted);
    text-align: center;
    padding: 0.5rem 1rem 0.65rem;
    font-style: italic;
    line-height: 1.5;
  }
</style>
