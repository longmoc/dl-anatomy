---
interface Props {
  lang?: 'vi' | 'en';
}
const { lang = 'vi' } = Astro.props;

const ui = lang === 'en'
  ? {
      caption: 'We never have the true data distribution — only samples from it. A generative model learns a distribution pθ that matches the data: the more samples constrain it, the closer pθ (green) is shaped to the true distribution (faint blue) and the divergence D(p_data ‖ pθ) goes to 0. This matching is the basis of every generative model.',
    }
  : {
      caption: 'Ta không có phân phối dữ liệu thật, chỉ có các sample của nó. Generative model học một phân phối pθ sao cho khớp với dữ liệu: càng nhiều sample ràng buộc, pθ (xanh lá) càng được nắn sát phân phối thật (nét xanh dương mờ) và divergence D(p_data ‖ pθ) tiến về 0. Việc khớp phân phối này là nền của mọi generative model.',
    };
---

<div class="dmv" data-lang={lang}>
  <canvas class="dmv-canvas"></canvas>
  <p class="dmv-caption">{ui.caption}</p>
</div>

<script>
document.querySelectorAll('.dmv').forEach(root => {
  const canvas = root.querySelector('.dmv-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const isEn = (root as HTMLElement).dataset.lang === 'en';
  const T = {
    matching: isEn ? 'matching…' : 'đang khớp…',
    matched: isEn ? 'matched ✓' : 'đã khớp ✓',
    data: 'p_data', model: 'pθ',
  };
  const cv = (n: string) => getComputedStyle(document.documentElement).getPropertyValue(n).trim();

  // ---- true data distribution over x ∈ [0,1] ----
  const N = 150;
  const gx = (i: number) => i / (N - 1);
  const dx = 1 / (N - 1);
  const g = (x: number, mu: number, sig: number) => Math.exp(-0.5 * ((x - mu) / sig) ** 2);
  const norm = (a: number[]) => { let s = 0; for (const v of a) s += v * dx; return a.map(v => v / s); };
  const target = norm(Array.from({ length: N }, (_, i) => 0.62 * g(gx(i), 0.30, 0.072) + 0.52 * g(gx(i), 0.69, 0.060)));
  const PEAK = Math.max(...target);

  // sample x from a density grid via its CDF
  const sampleX = (dens: number[]) => {
    const u = Math.random(); let c = 0;
    for (let i = 0; i < N; i++) { c += dens[i] * dx; if (c >= u) return Math.min(1, Math.max(0, gx(i) + (Math.random() - 0.5) * dx)); }
    return 0.5;
  };

  // ---- fixed dataset of samples drawn from p_data ----
  const M = 46, bw = 0.045;
  const samplesX = Array.from({ length: M }, () => sampleX(target));
  const kern = (u: number) => Math.exp(-0.5 * (u / bw) ** 2);
  // scale so the FULL KDE peak matches the target peak
  let scale = 1; {
    const full = new Array(N).fill(0);
    for (let i = 0; i < N; i++) { let s = 0; for (const xs of samplesX) s += kern(gx(i) - xs); full[i] = s; }
    scale = PEAK / Math.max(...full);
  }

  // ---- animation state ----
  let order: number[] = [];
  const revealT = new Array(M).fill(-1);
  let dispP = new Array(N).fill(0);
  let lastK = 0, cycleStart = -1;
  const shuffle = () => { order = [...Array(M).keys()]; for (let i = M - 1; i > 0; i--) { const j = Math.floor(Math.random() * (i + 1)); [order[i], order[j]] = [order[j], order[i]]; } };
  shuffle();

  const PL = 14, PR = 14, PT = 36, PB = 34;
  let W = 0, H = 0;
  const tx = (x: number) => PL + x * (W - PL - PR);
  const baseY = () => H - PB;
  const ty = (d: number) => baseY() - (d / PEAK) * (H - PT - PB) * 0.9;
  const easeInOut = (p: number) => (p < 0.5 ? 2 * p * p : 1 - (-2 * p + 2) ** 2 / 2);
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  let last = performance.now();

  function frame(now: number) {
    const dt = Math.min(0.05, (now - last) / 1000); last = now;
    const rect = canvas.getBoundingClientRect();
    W = rect.width; H = rect.height;
    if (W && H) {
      const dpr = window.devicePixelRatio || 1;
      if (canvas.width !== Math.round(W * dpr)) { canvas.width = Math.round(W * dpr); canvas.height = Math.round(H * dpr); }
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

      const fillDur = 4.4, holdDur = 1.5, total = fillDur + holdDur;
      let k: number;
      if (reduce) {
        k = M;
      } else {
        if (cycleStart < 0) cycleStart = now;
        let tt = (now - cycleStart) / 1000;
        if (tt > total) { shuffle(); revealT.fill(-1); dispP = new Array(N).fill(0); lastK = 0; cycleStart = now; tt = 0; }
        const fillP = Math.min(1, tt / fillDur);
        k = Math.round(easeInOut(fillP) * M);
      }
      if (k > lastK) { for (let j = lastK; j < k; j++) revealT[order[j]] = now; lastK = k; }

      // KDE of revealed samples → display target, eased
      const kde = new Array(N).fill(0);
      for (let m = 0; m < k; m++) { const xs = samplesX[order[m]]; for (let i = 0; i < N; i++) kde[i] += kern(gx(i) - xs); }
      for (let i = 0; i < N; i++) { const d = kde[i] * scale; dispP[i] += reduce ? (d - dispP[i]) : (d - dispP[i]) * Math.min(1, dt * 6); }

      // divergence on area-normalized shapes
      let sumP = 0; for (let i = 0; i < N; i++) sumP += dispP[i] * dx;
      let D = 0.5;
      if (sumP > 1e-6) { D = 0; for (let i = 0; i < N; i++) D += Math.abs(target[i] - dispP[i] / sumP) * dx; D *= 0.5; }

      const bg = cv('--bg'), border = cv('--border'), muted = cv('--muted');
      const data = cv('--accent'), model = cv('--accent2'), amber = cv('--amber'), text = cv('--text');

      ctx.fillStyle = bg; ctx.fillRect(0, 0, W, H);
      ctx.strokeStyle = border; ctx.lineWidth = 1;
      ctx.beginPath(); ctx.moveTo(PL, baseY()); ctx.lineTo(W - PR, baseY()); ctx.stroke();

      // target (true data distribution) — faint dashed outline
      ctx.strokeStyle = data; ctx.lineWidth = 1.6; ctx.globalAlpha = 0.5; ctx.setLineDash([5, 4]);
      ctx.beginPath();
      for (let i = 0; i < N; i++) { const X = tx(gx(i)), Y = ty(target[i]); i === 0 ? ctx.moveTo(X, Y) : ctx.lineTo(X, Y); }
      ctx.stroke(); ctx.setLineDash([]); ctx.globalAlpha = 1;

      // pθ built from samples — filled area + outline
      ctx.beginPath(); ctx.moveTo(tx(0), baseY());
      for (let i = 0; i < N; i++) ctx.lineTo(tx(gx(i)), ty(dispP[i]));
      ctx.lineTo(tx(1), baseY()); ctx.closePath();
      ctx.fillStyle = model + '33'; ctx.fill();
      ctx.beginPath();
      for (let i = 0; i < N; i++) { const X = tx(gx(i)), Y = ty(dispP[i]); i === 0 ? ctx.moveTo(X, Y) : ctx.lineTo(X, Y); }
      ctx.strokeStyle = model; ctx.lineWidth = 2; ctx.stroke();

      // revealed data samples as ticks below the axis (newest highlighted)
      ctx.lineWidth = 1.8;
      for (let m = 0; m < k; m++) {
        const idx = order[m]; const X = tx(samplesX[idx]);
        const age = revealT[idx] >= 0 ? (now - revealT[idx]) / 1000 : 1;
        const sc = reduce ? 1 : Math.min(1, age / 0.28);
        ctx.strokeStyle = (!reduce && age < 0.32) ? amber : data;
        ctx.globalAlpha = 0.85;
        ctx.beginPath(); ctx.moveTo(X, baseY() + 2); ctx.lineTo(X, baseY() + 2 + 10 * sc); ctx.stroke();
      }
      ctx.globalAlpha = 1;

      // legend
      ctx.font = '11px var(--mono, monospace)'; ctx.textAlign = 'left';
      ctx.fillStyle = data; ctx.fillRect(PL + 2, PT - 24, 12, 4);
      ctx.fillStyle = muted; ctx.fillText(T.data, PL + 18, PT - 20);
      ctx.fillStyle = model; ctx.fillRect(PL + 78, PT - 24, 12, 4);
      ctx.fillStyle = muted; ctx.fillText(T.model, PL + 94, PT - 20);

      // count + divergence + status (top-right)
      ctx.textAlign = 'right'; ctx.fillStyle = muted; ctx.font = '11px var(--mono, monospace)';
      ctx.fillText(`samples ${k}/${M}    D = ${D.toFixed(2)}`, W - PR - 2, PT - 20);
      const done = k >= M;
      ctx.fillStyle = done ? model : muted; ctx.font = 'bold 11px var(--mono, monospace)';
      ctx.fillText(done ? T.matched : T.matching, W - PR - 2, PT - 6);

      ctx.fillStyle = muted; ctx.font = '10px var(--mono, monospace)'; ctx.textAlign = 'center';
      ctx.fillText('x', PL + (W - PL - PR) / 2, H - 6);
    }
    if (!reduce) rafId = requestAnimationFrame(frame);
  }

  let rafId = 0;
  const io = new IntersectionObserver(entries => {
    for (const e of entries) {
      if (e.isIntersecting && !rafId) { last = performance.now(); rafId = requestAnimationFrame(frame); }
      else if (!e.isIntersecting && rafId) { cancelAnimationFrame(rafId); rafId = 0; }
    }
  }, { threshold: 0.05 });
  io.observe(canvas);
  const ro = new ResizeObserver(() => { if (!rafId) requestAnimationFrame(frame); });
  ro.observe(canvas);
});
</script>

<style>
  .dmv {
    margin: 1.5rem 0;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    background: var(--bg2);
  }
  .dmv-canvas {
    width: 100%;
    height: 220px;
    display: block;
    background: var(--bg);
  }
  .dmv-caption {
    font-size: 0.78rem;
    color: var(--muted);
    text-align: center;
    padding: 0.5rem 1rem 0.65rem;
    font-style: italic;
    line-height: 1.5;
  }
</style>
