---
interface Props {
  lang?: 'vi' | 'en';
}
const { lang = 'vi' } = Astro.props;

const L = lang === 'en'
  ? {
      title: 'Sampling & distribution matching',
      data: 'real data',
      model: 'model samples',
      latent: 'z ~ p(z)',
      gen: 'Gθ(z)',
      match: 'distribution matching',
      div: 'min D(p_data ‖ pθ)',
      cap: 'A generative model defines a sampler: draw simple noise z, push it through Gθ to get model samples from pθ. Training adjusts θ so the model sample cloud matches the real data cloud — i.e. minimize a divergence between p_data and pθ. Model families differ in how the sampler and the matching loss are defined.',
    }
  : {
      title: 'Sampling & distribution matching',
      data: 'dữ liệu thật',
      model: 'sample từ model',
      latent: 'z ~ p(z)',
      gen: 'Gθ(z)',
      match: 'khớp phân phối',
      div: 'min D(p_data ‖ pθ)',
      cap: 'Một generative model định nghĩa một sampler: lấy nhiễu đơn giản z, đẩy qua Gθ để ra sample từ pθ. Training chỉnh θ sao cho đám sample của model khớp với đám dữ liệu thật — tức minimize một divergence giữa p_data và pθ. Các họ model khác nhau ở cách định nghĩa sampler và loss matching.',
    };

const dataDots = [
  [98, 200], [126, 182], [150, 210], [174, 190], [198, 206], [224, 184],
  [150, 238], [182, 244], [212, 232], [120, 258], [164, 268], [206, 262], [238, 244],
  [112, 222], [244, 212],
];
const modelDots = [
  [520, 204], [548, 184], [574, 214], [596, 192], [620, 208], [646, 186],
  [572, 240], [604, 248], [636, 234], [542, 260], [586, 270], [628, 262], [660, 242],
  [666, 214], [530, 228],
];
const bell = (cx: number, cy: number) =>
  `M${cx - 15},${cy} C${cx - 7},${cy} ${cx - 5},${cy - 15} ${cx},${cy - 15} C${cx + 5},${cy - 15} ${cx + 7},${cy} ${cx + 15},${cy}`;
---

<figure class="sdm" data-lang={lang}>
  <svg viewBox="0 0 760 314" role="img" aria-label="Sampling and distribution matching diagram" class="sdm-svg">
    <defs>
      <marker id="sdm-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6.5" markerHeight="6.5" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" class="sdm-head" />
      </marker>
      <marker id="sdm-arrow2" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6.5" markerHeight="6.5" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" class="sdm-head2" />
      </marker>
    </defs>

    <text x="380" y="26" class="sdm-title">{L.title}</text>

    <!-- ===== sampler feeding the model panel (top) ===== -->
    <text x="468" y="70" class="sdm-small">{L.latent}</text>
    <path d={bell(468, 96)} class="sdm-bell" fill="none" />
    <line x1="486" y1="92" x2="506" y2="92" class="sdm-gline" marker-end="url(#sdm-arrow2)" />
    <rect x="510" y="76" width="86" height="32" rx="8" class="sdm-gen" />
    <text x="553" y="96" class="sdm-glabel">{L.gen}</text>
    <line x1="553" y1="108" x2="553" y2="120" class="sdm-gline" marker-end="url(#sdm-arrow2)" />

    <!-- ===== data cloud (left) ===== -->
    <rect x="50" y="122" width="236" height="166" rx="12" class="sdm-panel sdm-data-panel" />
    <text x="168" y="146" class="sdm-label">p_data(x)</text>
    <text x="168" y="164" class="sdm-small">{L.data}</text>
    {dataDots.map(([x, y]) => <circle cx={x} cy={y} r="5" class="sdm-data-dot" />)}

    <!-- ===== model cloud (right) ===== -->
    <rect x="474" y="122" width="236" height="166" rx="12" class="sdm-panel sdm-model-panel" />
    <text x="592" y="146" class="sdm-label">pθ(x)</text>
    <text x="592" y="164" class="sdm-small">{L.model}</text>
    {modelDots.map(([x, y]) => <circle cx={x} cy={y} r="5" class="sdm-model-dot" />)}

    <!-- ===== matching (center) ===== -->
    <text x="380" y="190" class="sdm-approx">≈</text>
    <line x1="288" y1="205" x2="472" y2="205" class="sdm-match" marker-start="url(#sdm-arrow)" marker-end="url(#sdm-arrow)" />
    <text x="380" y="228" class="sdm-match-label">{L.match}</text>
    <text x="380" y="244" class="sdm-div">{L.div}</text>
  </svg>
  <figcaption class="sdm-cap">{L.cap}</figcaption>
</figure>

<style>
  .sdm {
    margin: 1.75rem 0;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--bg2);
    padding: 0.75rem 0 0.2rem;
  }
  .sdm-svg { display: block; width: 100%; max-width: 820px; height: auto; margin: 0 auto; }
  .sdm-title { fill: var(--text); font-family: var(--mono); font-size: 13px; font-weight: 600; text-anchor: middle; }
  .sdm-panel { fill: var(--bg); stroke-width: 1.8; }
  .sdm-data-panel { stroke: var(--accent); }
  .sdm-model-panel { stroke: var(--accent2); }
  .sdm-gen { fill: var(--bg); stroke: var(--amber); stroke-width: 1.8; }
  .sdm-bell { stroke: var(--muted); stroke-width: 1.6; }
  .sdm-label, .sdm-small, .sdm-glabel, .sdm-match-label, .sdm-div, .sdm-approx {
    font-family: var(--mono);
    text-anchor: middle;
  }
  .sdm-label { fill: var(--text); font-size: 12.5px; font-weight: 700; }
  .sdm-small { fill: var(--muted); font-size: 10.5px; }
  .sdm-glabel { fill: var(--text); font-size: 12px; font-weight: 600; }
  .sdm-data-dot { fill: var(--accent); fill-opacity: 0.78; stroke: var(--bg2); stroke-width: 1; }
  .sdm-model-dot { fill: var(--accent2); fill-opacity: 0.78; stroke: var(--bg2); stroke-width: 1; }
  .sdm-gline { stroke: var(--amber); stroke-width: 1.7; }
  .sdm-head2 { fill: var(--amber); }
  .sdm-match { stroke: var(--muted); stroke-width: 1.6; stroke-dasharray: 5 4; }
  .sdm-head { fill: var(--muted); }
  .sdm-approx { fill: var(--text); font-size: 22px; font-weight: 700; }
  .sdm-match-label { fill: var(--muted); font-size: 11px; font-weight: 600; }
  .sdm-div { fill: var(--muted); font-size: 10.5px; }
  .sdm-cap {
    font-size: 0.78rem;
    color: var(--muted);
    text-align: center;
    padding: 0.5rem 1rem 0.65rem;
    font-style: italic;
    line-height: 1.5;
  }
</style>
