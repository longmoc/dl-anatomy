---
interface Props {
  lang?: 'vi' | 'en';
}
const { lang = 'vi' } = Astro.props;

const L = lang === 'en'
  ? {
      title: 'Sampling and distribution matching',
      data: 'real data samples',
      model: 'model samples',
      latent: 'simple noise z',
      sampler: 'sampler / generator',
      match: 'train until sample clouds match',
      cap: 'A generative model is useful when samples from pθ look like samples from the real data distribution. Different model families choose different ways to define the sampler and different losses for matching the two distributions.',
    }
  : {
      title: 'Sampling và distribution matching',
      data: 'sample dữ liệu thật',
      model: 'sample từ model',
      latent: 'nhiễu đơn giản z',
      sampler: 'sampler / generator',
      match: 'train để hai đám sample khớp nhau',
      cap: 'Một generative model hữu ích khi sample từ pθ trông giống sample từ phân phối dữ liệu thật. Các họ model khác nhau chọn cách định nghĩa sampler và loss matching khác nhau.',
    };

const dataDots = [
  [94, 148], [116, 126], [134, 160], [154, 137], [178, 154], [205, 126],
  [230, 144], [252, 164], [112, 198], [145, 220], [174, 204], [214, 214], [246, 198],
];
const modelDots = [
  [488, 148], [510, 126], [530, 160], [552, 138], [575, 153], [604, 129],
  [630, 146], [650, 168], [508, 198], [540, 218], [570, 204], [612, 216], [644, 198],
];
const noiseDots = [[335, 102], [354, 88], [374, 104], [394, 88], [414, 102]];
---

<figure class="sdm" data-lang={lang}>
  <svg viewBox="0 0 760 316" role="img" aria-label="Sampling and distribution matching diagram" class="sdm-svg">
    <defs>
      <marker id="sdm-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" class="sdm-head" />
      </marker>
      <marker id="sdm-arrow2" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" class="sdm-head2" />
      </marker>
    </defs>

    <text x="380" y="27" class="sdm-title">{L.title}</text>

    <rect x="54" y="78" width="236" height="176" rx="12" class="sdm-panel sdm-data-panel" />
    <text x="172" y="102" class="sdm-label">p_data(x)</text>
    <text x="172" y="121" class="sdm-small">{L.data}</text>
    {dataDots.map(([x, y]) => <circle cx={x} cy={y} r="5" class="sdm-data-dot" />)}

    <rect x="320" y="72" width="120" height="64" rx="10" class="sdm-noise" />
    <text x="380" y="94" class="sdm-label">z ~ p(z)</text>
    <text x="380" y="114" class="sdm-small">{L.latent}</text>
    {noiseDots.map(([x, y]) => <circle cx={x} cy={y} r="3.2" class="sdm-noise-dot" />)}

    <rect x="310" y="178" width="140" height="62" rx="10" class="sdm-gen" />
    <text x="380" y="204" class="sdm-label">Gθ(z)</text>
    <text x="380" y="224" class="sdm-small">{L.sampler}</text>

    <line x1="380" y1="136" x2="380" y2="178" class="sdm-line2" marker-end="url(#sdm-arrow2)" />
    <line x1="450" y1="209" x2="482" y2="209" class="sdm-line2" marker-end="url(#sdm-arrow2)" />

    <rect x="482" y="78" width="236" height="176" rx="12" class="sdm-panel sdm-model-panel" />
    <text x="600" y="102" class="sdm-label">pθ(x)</text>
    <text x="600" y="121" class="sdm-small">{L.model}</text>
    {modelDots.map(([x, y]) => <circle cx={x} cy={y} r="5" class="sdm-model-dot" />)}

    <path d="M290,258 C380,296 482,296 572,258" class="sdm-match" fill="none" marker-end="url(#sdm-arrow)" />
    <text x="380" y="292" class="sdm-match-label">{L.match}</text>
  </svg>
  <figcaption class="sdm-cap">{L.cap}</figcaption>
</figure>

<style>
  .sdm {
    margin: 1.75rem 0;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--bg2);
    padding: 0.75rem 0 0.2rem;
  }
  .sdm-svg { display: block; width: 100%; max-width: 820px; height: auto; margin: 0 auto; }
  .sdm-title { fill: var(--text); font-family: var(--mono); font-size: 13px; font-weight: 600; text-anchor: middle; }
  .sdm-panel, .sdm-noise, .sdm-gen { fill: var(--bg); stroke-width: 1.8; }
  .sdm-data-panel { stroke: var(--accent); }
  .sdm-model-panel { stroke: var(--accent2); }
  .sdm-noise { stroke: var(--muted); }
  .sdm-gen { stroke: var(--amber); }
  .sdm-label, .sdm-small, .sdm-match-label {
    font-family: var(--mono);
    text-anchor: middle;
  }
  .sdm-label { fill: var(--text); font-size: 12.5px; font-weight: 700; }
  .sdm-small { fill: var(--muted); font-size: 10px; }
  .sdm-data-dot { fill: var(--accent); fill-opacity: 0.78; stroke: var(--bg2); stroke-width: 1; }
  .sdm-model-dot { fill: var(--accent2); fill-opacity: 0.78; stroke: var(--bg2); stroke-width: 1; }
  .sdm-noise-dot { fill: var(--muted); }
  .sdm-line2 { stroke: var(--amber); stroke-width: 1.7; }
  .sdm-head2 { fill: var(--amber); }
  .sdm-match { stroke: var(--muted); stroke-width: 1.6; stroke-dasharray: 5 4; }
  .sdm-head { fill: var(--muted); }
  .sdm-match-label { fill: var(--muted); font-size: 10.5px; }
  .sdm-cap {
    font-size: 0.78rem;
    color: var(--muted);
    text-align: center;
    padding: 0.5rem 1rem 0.65rem;
    font-style: italic;
    line-height: 1.5;
  }
</style>
