---
interface Props {
  lang?: 'vi' | 'en';
}
const { lang = 'vi' } = Astro.props;

const ui = lang === 'en'
  ? {
      kernel: 'Kernel',
      edge: 'Edge', blur: 'Blur', sharpen: 'Sharpen', identity: 'Identity',
      input: 'Input', feat: 'Feature map',
      caption: 'A 3×3 kernel slides over the input; at each position the output is the weighted sum of the patch it covers. The same kernel is reused everywhere (weight sharing) → it detects one feature at every location. Switch kernels to see what each one extracts.',
    }
  : {
      kernel: 'Kernel',
      edge: 'Cạnh', blur: 'Làm mờ', sharpen: 'Làm nét', identity: 'Giữ nguyên',
      input: 'Input', feat: 'Feature map',
      caption: 'Một kernel 3×3 trượt trên input; mỗi vị trí cho output = tổng có trọng số của vùng nó phủ. Cùng một kernel dùng lại khắp nơi (weight sharing) → phát hiện một đặc trưng ở mọi vị trí. Đổi kernel để xem mỗi loại trích ra gì.',
    };
---

<div class="cvz" data-lang={lang}>
  <canvas class="cvz-canvas"></canvas>
  <div class="cvz-controls">
    <span class="cvz-lbl">{ui.kernel}:</span>
    <button class="cvz-k cvz-active" data-k="edge">{ui.edge}</button>
    <button class="cvz-k" data-k="blur">{ui.blur}</button>
    <button class="cvz-k" data-k="sharpen">{ui.sharpen}</button>
    <button class="cvz-k" data-k="identity">{ui.identity}</button>
  </div>
  <p class="cvz-caption">{ui.caption}</p>
</div>

<script>
document.querySelectorAll('.cvz').forEach(root => {
  const canvas = root.querySelector('.cvz-canvas') as HTMLCanvasElement;
  const ctx    = canvas.getContext('2d')!;
  const isEn   = (root as HTMLElement).dataset.lang === 'en';
  const cv = (n: string) => getComputedStyle(document.documentElement).getPropertyValue(n).trim();

  // Input image: a 9×9 grayscale grid with a diagonal edge + a square — gives visible edges.
  const N = 9;
  const input: number[][] = [];
  for (let r = 0; r < N; r++) {
    input.push([]);
    for (let c = 0; c < N; c++) {
      // bright square in top-left region + diagonal split
      let v = (r + c < N) ? 0.85 : 0.15;
      if (r >= 2 && r <= 4 && c >= 4 && c <= 6) v = 0.95; // a bright block
      input[r].push(v);
    }
  }

  const KERNELS: Record<string, number[][]> = {
    edge:     [[-1,-1,-1],[-1, 8,-1],[-1,-1,-1]],
    blur:     [[1/9,1/9,1/9],[1/9,1/9,1/9],[1/9,1/9,1/9]],
    sharpen:  [[0,-1,0],[-1,5,-1],[0,-1,0]],
    identity: [[0,0,0],[0,1,0],[0,0,0]],
  };
  let kernelName = 'edge';

  const M = N - 2; // valid conv output size (no padding) = 7
  function conv(): number[][] {
    const K = KERNELS[kernelName];
    const out: number[][] = [];
    for (let r = 0; r < M; r++) {
      out.push([]);
      for (let c = 0; c < M; c++) {
        let s = 0;
        for (let i = 0; i < 3; i++) for (let j = 0; j < 3; j++) s += input[r+i][c+j] * K[i][j];
        out[r].push(s);
      }
    }
    return out;
  }

  // animated sliding position over the M×M output
  let pos = 0; // 0..M*M-1
  let lastT = 0;

  function gray(v: number, bright: string, dark: string): string {
    // map v∈[~-? ..] clamp 0..1 to interpolation dark→bright
    const t = Math.max(0, Math.min(1, v));
    const a = hexToRgb(dark)!, b = hexToRgb(bright)!;
    const r = Math.round(a.r + (b.r - a.r) * t);
    const g = Math.round(a.g + (b.g - a.g) * t);
    const bl = Math.round(a.b + (b.b - a.b) * t);
    return `rgb(${r},${g},${bl})`;
  }
  function hexToRgb(h: string) {
    const m = h.replace('#','').match(/^([0-9a-f]{2})([0-9a-f]{2})([0-9a-f]{2})$/i);
    return m ? { r: parseInt(m[1],16), g: parseInt(m[2],16), b: parseInt(m[3],16) } : null;
  }

  let W = 0, H = 0;
  function draw() {
    const rect = canvas.getBoundingClientRect();
    W = rect.width; H = rect.height;
    if (!W || !H) return;
    const dpr = window.devicePixelRatio || 1;
    if (canvas.width !== W * dpr) { canvas.width = W * dpr; canvas.height = H * dpr; }
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

    const bg = cv('--bg'), muted = cv('--muted'), accent = cv('--accent'), amber = cv('--amber'), border = cv('--border'), text = cv('--text');
    // grayscale endpoints adapt to theme
    const darkSwatch = '#1a1a18', brightSwatch = '#e8e6df';

    ctx.fillStyle = bg;
    ctx.fillRect(0, 0, W, H);

    const out = conv();
    const or = Math.floor(pos / M), oc = pos % M;

    // layout: input grid (left), arrow, feature map (right)
    const pad = 16, gap = 30, labelH = 16;
    const avail = W - pad * 2 - gap;
    const cellIn = Math.min((avail * 0.52) / N, (H - pad * 2 - labelH) / N);
    const cellOut = Math.min((avail * 0.48) / M, (H - pad * 2 - labelH) / M);
    const inW = cellIn * N, outW = cellOut * M;
    const inX = pad, gy = pad + labelH;
    const inY = gy + ((H - pad*2 - labelH) - cellIn*N)/2;
    const outX = W - pad - outW;
    const outY = gy + ((H - pad*2 - labelH) - cellOut*M)/2;

    // labels
    ctx.font = '11px var(--mono, monospace)';
    ctx.fillStyle = muted;
    ctx.textAlign = 'left';
    ctx.fillText(isEn ? 'Input' : 'Input', inX, pad + 10);
    ctx.textAlign = 'right';
    ctx.fillText(isEn ? 'Feature map' : 'Feature map', outX + outW, pad + 10);

    // input cells
    for (let r = 0; r < N; r++) for (let c = 0; c < N; c++) {
      ctx.fillStyle = gray(input[r][c], brightSwatch, darkSwatch);
      ctx.fillRect(inX + c*cellIn, inY + r*cellIn, cellIn-1, cellIn-1);
    }
    // highlight current 3×3 patch
    ctx.strokeStyle = amber;
    ctx.lineWidth = 2.5;
    ctx.strokeRect(inX + oc*cellIn - 0.5, inY + or*cellIn - 0.5, 3*cellIn, 3*cellIn);

    // output cells (computed so far)
    const idxNow = pos;
    let k = 0;
    // normalize output for display: edge/sharpen can be negative → map around 0.5
    for (let r = 0; r < M; r++) for (let c = 0; c < M; c++) {
      const filled = (r * M + c) <= idxNow;
      let v = out[r][c];
      // display mapping: blur/identity already 0..1; edge/sharpen center at 0
      const disp = (kernelName === 'blur' || kernelName === 'identity') ? v : 0.5 + v * 0.5;
      ctx.fillStyle = filled ? gray(disp, brightSwatch, darkSwatch) : cv('--bg2');
      ctx.fillRect(outX + c*cellOut, outY + r*cellOut, cellOut-1, cellOut-1);
      k++;
    }
    // highlight current output cell
    ctx.strokeStyle = amber;
    ctx.lineWidth = 2.5;
    ctx.strokeRect(outX + oc*cellOut - 0.5, outY + or*cellOut - 0.5, cellOut, cellOut);

    // arrow + kernel label in the middle
    const midX = inX + inW + gap/2;
    const midY = H / 2;
    ctx.strokeStyle = accent;
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.moveTo(inX + inW + 6, midY);
    ctx.lineTo(outX - 6, midY);
    ctx.stroke();
    // arrowhead
    ctx.beginPath();
    ctx.moveTo(outX - 6, midY); ctx.lineTo(outX - 13, midY - 5); ctx.lineTo(outX - 13, midY + 5);
    ctx.closePath(); ctx.fillStyle = accent; ctx.fill();
    ctx.fillStyle = accent;
    ctx.font = 'bold 10px var(--mono, monospace)';
    ctx.textAlign = 'center';
    ctx.fillText('∗', midX, midY - 8);
    ctx.fillStyle = muted;
    ctx.fillText('3×3', midX, midY + 16);
  }

  function loop(t: number) {
    if (t - lastT > 320) {
      pos = (pos + 1) % (M * M);
      lastT = t;
      draw();
    }
    requestAnimationFrame(loop);
  }

  root.querySelectorAll('.cvz-k').forEach(btn => {
    btn.addEventListener('click', () => {
      root.querySelectorAll('.cvz-k').forEach(b => b.classList.remove('cvz-active'));
      btn.classList.add('cvz-active');
      kernelName = (btn as HTMLElement).dataset.k!;
      pos = 0;
      draw();
    });
  });

  const ro = new ResizeObserver(draw);
  ro.observe(canvas);
  draw();
  requestAnimationFrame(loop);
});
</script>

<style>
  .cvz { margin: 1.75rem 0; border: 1px solid var(--border); border-radius: 10px; overflow: hidden; background: var(--bg2); }
  .cvz-canvas { width: 100%; height: 220px; display: block; background: var(--bg); }
  .cvz-controls { display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap; padding: 0.55rem 0.9rem; border-top: 1px solid var(--border); }
  .cvz-lbl { font-family: var(--mono); font-size: 0.77rem; color: var(--muted); }
  .cvz-k {
    font-family: var(--mono); font-size: 0.74rem; padding: 0.18em 0.6em;
    border: 1px solid var(--border); border-radius: 4px; background: var(--bg);
    color: var(--muted); cursor: pointer; transition: color 0.12s, border-color 0.12s, background 0.12s;
  }
  .cvz-k:hover { color: var(--text); border-color: var(--text); }
  .cvz-k.cvz-active { background: var(--accent); color: #fff; border-color: var(--accent); }
  .cvz-caption { font-size: 0.78rem; color: var(--muted); text-align: center; padding: 0.1rem 1rem 0.65rem; font-style: italic; line-height: 1.5; }
</style>
